@model List<CandyPlayer.Models.PlayHistory>

@{
    ViewData["Title"] = "播放历史";
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="fas fa-history"></i> 播放历史</h2>
        <p class="text-muted">查看您播放过的所有媒体</p>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>文件名</th>
                        <th style="width: 100px;">类型</th>
                        <th style="width: 160px;">播放时间</th>
                        <th style="width: 120px;">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var history in Model)
                    {
                        <tr>
                            <td>
                                @if (history.MediaFile?.MediaType == CandyPlayer.Models.MediaType.Music)
                                {
                                    <i class="fas fa-music text-primary me-2"></i>
                                }
                                else if (history.MediaFile?.MediaType == CandyPlayer.Models.MediaType.Video)
                                {
                                    <i class="fas fa-video text-danger me-2"></i>
                                }
                                else
                                {
                                    <i class="fas fa-book text-success me-2"></i>
                                }
                                @history.MediaFile?.FileName
                            </td>
                            <td>
                                @if (history.MediaFile?.MediaType == CandyPlayer.Models.MediaType.Music)
                                {
                                    <span class="badge bg-info">音乐</span>
                                }
                                else if (history.MediaFile?.MediaType == CandyPlayer.Models.MediaType.Video)
                                {
                                    <span class="badge bg-warning">视频</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">书籍</span>
                                }
                            </td>
                            <td>@history.PlayTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>
                                <a href="@Url.Action("Play", "Media", new { id = history.MediaFileId })" class="btn btn-sm btn-primary">
                                    <i class="fas fa-play"></i> 播放
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-history fa-4x text-muted mb-3"></i>
        <p class="text-muted">暂无播放记录</p>
        <a href="@Url.Action("Music", "Media")" class="btn btn-primary">
            <i class="fas fa-music"></i> 去听听音乐
        </a>
    </div>
}