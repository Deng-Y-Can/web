@{
    ViewData["Title"] = "访问被拒绝";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CandyPlayer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .access-denied-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            padding: 40px;
            width: 100%;
            max-width: 500px;
            text-align: center;
        }
        .access-denied-card i {
            font-size: 80px;
            color: #dc3545;
            margin-bottom: 20px;
        }
        .access-denied-card h2 {
            color: #dc3545;
            margin-bottom: 20px;
        }
        .btn-back {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            padding: 10px 30px;
        }
        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body>
    <div class="access-denied-card">
        <i class="fas fa-ban"></i>
        <h2>访问被拒绝</h2>
        <p class="text-muted">您没有权限访问此页面。</p>
        <p class="text-muted small">请确认您的账号权限或联系管理员。</p>
        <hr />
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-back">
            <i class="fas fa-home"></i> 返回首页
        </a>
    </div>
</body>
</html>