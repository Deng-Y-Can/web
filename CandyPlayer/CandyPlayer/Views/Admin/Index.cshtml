@{
    ViewData["Title"] = "管理面板";
    var stats = ViewBag.Stats;
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="fas fa-cog"></i> 管理面板</h2>
        <p class="text-muted">欢迎回来，管理员！</p>
    </div>
</div>

<div class="row">
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">用户总数</h5>
                <h2 class="mb-0">@stats.TotalUsers</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">文件总数</h5>
                <h2 class="mb-0">@stats.TotalFiles</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title">书籍</h5>
                <h2 class="mb-0">@stats.Books</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">音乐</h5>
                <h2 class="mb-0">@stats.Music</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-danger">
            <div class="card-body">
                <h5 class="card-title">视频</h5>
                <h2 class="mb-0">@stats.Videos</h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-tools"></i> 快速操作</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="@Url.Action("Users", "Admin")" class="btn btn-primary">
                        <i class="fas fa-users"></i> 用户管理
                    </a>
                    <a href="@Url.Action("Logs", "Admin")" class="btn btn-info">
                        <i class="fas fa-history"></i> 查看日志
                    </a>
                    <button onclick="refreshFiles()" class="btn btn-success">
                        <i class="fas fa-sync-alt"></i> 手动刷新文件
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-chart-bar"></i> 系统信息</h5>
            </div>
            <div class="card-body">
                <p><strong>数据库类型:</strong> SQLite</p>
                <p><strong>媒体路径:</strong> D:\CandyPlayer</p>
                <p><strong>会话超时:</strong> 30分钟</p>
                <p><strong>分页大小:</strong> 20条/页</p>
                <p><strong>.NET 版本:</strong> 8.0</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function refreshFiles() {
            if (confirm('确定要刷新文件吗？这将扫描整个媒体文件夹并同步数据库。')) {
                $.ajax({
                    url: '@Url.Action("RefreshFiles", "Admin")',
                    type: 'POST',
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(result) {
                        if (result.success) {
                            alert('文件刷新成功');
                            location.reload();
                        } else {
                            alert('文件刷新失败：' + result.message);
                        }
                    },
                    error: function() {
                        alert('文件刷新失败，请稍后重试');
                    }
                });
            }
        }
    </script>
}