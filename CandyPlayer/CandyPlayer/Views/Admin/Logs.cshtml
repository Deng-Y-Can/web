@model List<CandyPlayer.Models.OperationLog>

@{
    ViewData["Title"] = "操作日志";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="fas fa-history"></i> 操作日志</h2>
        <p class="text-muted">查看所有用户的操作记录</p>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th style="width: 120px;">用户名</th>
                        <th style="width: 100px;">操作类型</th>
                        <th>操作内容</th>
                        <th style="width: 160px;">操作时间</th>
                        <th style="width: 140px;">IP地址</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td>@log.LogId</td>
                            <td>@log.Username</td>
                            <td>
                                @{
                                    var icon = log.OperationType switch
                                    {
                                        CandyPlayer.Models.OperationType.Login => "fa-sign-in-alt",
                                        CandyPlayer.Models.OperationType.Logout => "fa-sign-out-alt",
                                        CandyPlayer.Models.OperationType.Upload => "fa-upload",
                                        CandyPlayer.Models.OperationType.Delete => "fa-trash",
                                        CandyPlayer.Models.OperationType.Move => "fa-arrows-alt",
                                        CandyPlayer.Models.OperationType.Rename => "fa-edit",
                                        CandyPlayer.Models.OperationType.Refresh => "fa-sync",
                                        CandyPlayer.Models.OperationType.Download => "fa-download",
                                        CandyPlayer.Models.OperationType.Play => "fa-play",
                                        _ => "fa-info-circle"
                                    };
                                }
                                <i class="fas @icon"></i> @log.OperationType
                            </td>
                            <td>@log.OperationContent</td>
                            <td>@log.OperationTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@log.IPAddress</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-history fa-4x text-muted mb-3"></i>
        <p class="text-muted">暂无操作日志</p>
    </div>
}

@if (totalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= totalPages && i <= 10; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Logs", new { page = i })">@i</a>
                </li>
            }
        </ul>
    </nav>
}