@model List<CandyPlayer.Models.User>

@{
    ViewData["Title"] = "用户管理";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var searchKeyword = ViewBag.SearchKeyword as string ?? "";
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="fas fa-users"></i> 用户管理</h2>
        <p class="text-muted">管理系统用户账号</p>
    </div>
    <div class="col text-end">
        <a href="@Url.Action("AddUser", "Admin")" class="btn btn-primary">
            <i class="fas fa-user-plus"></i> 添加用户
        </a>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" id="searchInput" class="form-control" placeholder="搜索用户名..." value="@searchKeyword" />
            <button class="btn btn-outline-secondary" type="button" id="searchBtn">
                <i class="fas fa-search"></i>
            </button>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>用户名</th>
                        <th style="width: 120px;">角色</th>
                        <th style="width: 160px;">创建时间</th>
                        <th style="width: 160px;">最后登录</th>
                        <th style="width: 150px;">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.UserId</td>
                            <td>
                                <i class="fas fa-user-circle me-2 text-primary"></i>
                                @user.Username
                            </td>
                            <td>
                                @if (user.Role == CandyPlayer.Models.UserRole.Admin)
                                {
                                    <span class="badge bg-danger">管理员</span>
                                }
                                else if (user.Role == CandyPlayer.Models.UserRole.AdvancedUser)
                                {
                                    <span class="badge bg-warning text-dark">高级用户</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">普通用户</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(user.LastLoginTime?.ToString("yyyy-MM-dd HH:mm") ?? "未登录")</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="@Url.Action("EditUser", "Admin", new { id = user.UserId })" class="btn btn-outline-primary">
                                        <i class="fas fa-edit"></i> 编辑
                                    </a>
                                    @if (!(user.Role == CandyPlayer.Models.UserRole.Admin && Model.Count(u => u.Role == CandyPlayer.Models.UserRole.Admin) == 1))
                                    {
                                        <button onclick="deleteUser(@user.UserId)" class="btn btn-outline-danger">
                                            <i class="fas fa-trash"></i> 删除
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-users fa-4x text-muted mb-3"></i>
        <p class="text-muted">暂无用户数据</p>
    </div>
}

@if (totalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= totalPages && i <= 10; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Users", new { page = i, search = searchKeyword })">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        function deleteUser(userId) {
            if (confirm('确定要删除这个用户吗？此操作不可恢复！')) {
                $.ajax({
                    url: '@Url.Action("DeleteUser", "Admin")',
                    type: 'POST',
                    data: { id: userId },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(result) {
                        if (result.success) {
                            alert('删除成功');
                            location.reload();
                        } else {
                            alert('删除失败：' + result.message);
                        }
                    },
                    error: function() {
                        alert('删除失败，请稍后重试');
                    }
                });
            }
        }

        $('#searchBtn').click(function() {
            var keyword = $('#searchInput').val();
            window.location.href = '@Url.Action("Users")?search=' + encodeURIComponent(keyword);
        });

        $('#searchInput').keypress(function(e) {
            if (e.which === 13) $('#searchBtn').click();
        });
    </script>
}