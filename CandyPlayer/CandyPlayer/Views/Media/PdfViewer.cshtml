@{
    Layout = null;
    var fileId = ViewData["FileId"]?.ToString() ?? "";
    var fileName = ViewData["FileName"]?.ToString() ?? "PDF文件";
    var fileUrl = Url.Action("Stream", "Media", new { id = fileId });
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=2.0, user-scalable=yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>@fileName - PDF阅读器</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            background: #0a0a1a;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

    #toolbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 48px;
        background: rgba(10,10,26,0.95);
        backdrop-filter: blur(20px);
        display: flex;
        align-items: center;
        padding: 0 8px;
        z-index: 1000;
        box-shadow: 0 4px 30px rgba(0,0,0,0.5);
        border-bottom: 1px solid rgba(255,255,255,0.08);
        gap: 4px;
    }

    .toolbar-btn {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        color: #e2e8f0;
        height: 36px;
        border-radius: 10px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        transition: all 0.3s ease;
        min-width: 36px;
        padding: 0 8px;
        white-space: nowrap;
    }

    .toolbar-btn:hover {
        background: rgba(99,102,241,0.15);
        border-color: rgba(99,102,241,0.3);
    }

    .toolbar-btn:active {
        background: rgba(99,102,241,0.25);
        transform: scale(0.95);
    }

    .toolbar-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    .toolbar-divider {
        width: 1px;
        height: 24px;
        background: rgba(255,255,255,0.08);
        margin: 0 4px;
    }

    .toolbar-title {
        flex: 1;
        color: #e2e8f0;
        font-size: 14px;
        text-align: center;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        padding: 0 8px;
        font-weight: 500;
    }

        #pdfFrame {
            position: absolute;
            top: 48px;
            left: 0;
            right: 0;
            bottom: 0;
            width: 100%;
            height: calc(100% - 48px);
            border: none;
        }

        #loading {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #e2e8f0;
            font-size: 16px;
            text-align: center;
            z-index: 2000;
        }

        .loading-spinner {
            width: 40px;
            height: 40px;
            border: 3px solid rgba(99,102,241,0.2);
            border-top-color: #818cf8;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 12px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        @media (max-width: 768px) {
            #toolbar {
                height: 44px;
                padding: 0 4px;
                gap: 2px;
            }

            .toolbar-btn {
                height: 32px;
                font-size: 14px;
                min-width: 32px;
                padding: 0 6px;
            }

            .toolbar-title {
                font-size: 12px;
            }

            .toolbar-divider {
                margin: 0 2px;
            }

            #pdfFrame {
                top: 44px;
                height: calc(100% - 44px);
            }
        }
    </style>
</head>
<body>
    <div id="toolbar">
        <button class="toolbar-btn" id="backBtn" title="返回" onclick="window.history.back()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
        </button>
        <div class="toolbar-divider"></div>
        <div class="toolbar-title">@fileName</div>
        <div class="toolbar-divider"></div>
        <button class="toolbar-btn" id="downloadBtn" title="下载">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
            </svg>
        </button>
    </div>

    <iframe id="pdfFrame" src="@fileUrl"></iframe>

    <div id="loading">
        <div class="loading-spinner"></div>
        <div>正在加载PDF...</div>
    </div>

    <script>
        (function() {
            var pdfFrame = document.getElementById('pdfFrame');
            var loading = document.getElementById('loading');

            pdfFrame.addEventListener('load', function() {
                loading.style.display = 'none';
            });

            pdfFrame.addEventListener('error', function() {
                loading.innerHTML = '<div style="color:#ff6b6b;text-align:center;padding:20px;background:rgba(0,0,0,0.8);border-radius:8px;">' +
                    '<h3 style="margin-bottom:8px;">加载失败</h3>' +
                    '<p>无法加载PDF文件</p>' +
                    '<button onclick="location.reload()" style="margin-top:12px;padding:8px 16px;background:rgba(255,255,255,0.2);border:none;color:#fff;border-radius:6px;cursor:pointer;">重新加载</button>' +
                    '</div>';
            });

            document.getElementById('downloadBtn').addEventListener('click', function() {
                var a = document.createElement('a');
                a.href = '@fileUrl'.replace('Stream', 'Download');
                a.download = '';
                a.click();
            });

            setTimeout(function() {
                if (loading.style.display !== 'none') {
                    loading.style.display = 'none';
                }
            }, 5000);
        })();
    </script>
</body>
</html>
