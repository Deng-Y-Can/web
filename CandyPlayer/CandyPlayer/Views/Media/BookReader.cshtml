@model CandyPlayer.Models.MediaFile

@{
    ViewData["Title"] = "阅读器 - " + Model.FileName;
    var isPdf = Model.FileExtension.ToLower() == "pdf";
}

<link href="https://cdn.bootcdn.net/ajax/libs/bootstrap/5.1.3/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.bootcdn.net/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

<style>
    .reader-container {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        overflow: hidden;
    }

    .reader-controls {
        background: rgba(15,15,35,0.9) !important;
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    #readerContent {
        transition: all 0.3s ease;
        min-height: 70vh;
    }

    .txt-content {
        max-width: 800px;
        margin: 0 auto;
        text-align: justify;
    }

    #bookmarkPanel button {
        box-shadow: 0 4px 20px rgba(99,102,241,0.3);
        transition: all 0.3s ease;
    }

    #bookmarkPanel button:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 30px rgba(99,102,241,0.5);
    }
</style>

<div class="container-fluid px-2 px-md-4">
    <div class="row">
        <div class="col-12">
            <div class="card border-0">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 text-truncate me-2" style="font-size:1rem;">
                            <i class="fas fa-book"></i> @Model.FileName
                        </h5>
                        <div class="flex-shrink-0">
                            <a href="@Url.Action("Download", "Media", new { id = Model.FileId })" class="btn btn-sm btn-outline-light">
                                <i class="fas fa-download"></i> <span class="d-none d-sm-inline">下载</span>
                            </a>
                            <a href="@Url.Action("Books", "Media")" class="btn btn-sm btn-outline-light ms-1">
                                <i class="fas fa-arrow-left"></i> <span class="d-none d-sm-inline">返回列表</span>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="bookReaderContainer" class="reader-container" style="min-height: 70vh;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/bookReader.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var fileUrl = '@Url.Action("Stream", "Media", new { id = Model.FileId })';
        var fileType = '@(isPdf ? "pdf" : "txt")';
        var fileName = '@Model.FileName';
        var fileId = @Model.FileId;

        if (!window.bookReader || window.bookReader.fileName !== fileName) {
            window.bookReader = new BookReader('bookReaderContainer', fileUrl, fileType, fileName, fileId);
        }
    });
</script>