@model List<CandyPlayer.Models.MediaFile>

@{
    ViewData["Title"] = "我的书籍";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var searchKeyword = ViewBag.SearchKeyword as string ?? "";
    var currentFolder = ViewBag.CurrentFolder as string ?? "";
}

<style>
    .folder-tree {
        background: #fff;
        border-radius: 8px;
        padding: 16px 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .folder-tree-title {
        padding: 0 16px 12px;
        border-bottom: 1px solid #eee;
        margin-bottom: 8px;
        font-weight: 600;
        color: #333;
    }

    .folder-list, .sub-folders {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .folder-item {
        padding: 8px 16px;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .folder-item:hover {
        background: #f5f7fa;
    }

    .folder-item.active {
        background: #e8f0fe;
        color: #1976d2;
    }

    .folder-item .folder-icon {
        color: #f5a623;
    }

    .folder-item.active .folder-icon {
        color: #1976d2;
    }

    .folder-toggle {
        width: 16px;
        display: inline-flex;
        justify-content: center;
        transition: transform 0.2s;
        flex-shrink: 0;
        font-size: 10px;
        color: #999;
    }

    .folder-toggle.expanded {
        transform: rotate(90deg);
    }

    .sub-folders {
        padding-left: 24px;
        display: none;
    }

    .sub-folders.expanded {
        display: block;
    }

    .breadcrumb-item.folder-breadcrumb {
        cursor: pointer;
        color: #666;
    }

    .breadcrumb-item.folder-breadcrumb:hover {
        color: #1976d2;
        text-decoration: underline;
    }

    .breadcrumb-item.folder-breadcrumb.active {
        color: #333;
        cursor: default;
        text-decoration: none;
    }

    .folder-loading {
        padding: 16px;
        text-align: center;
        color: #999;
    }

    @@media (max-width: 991px) {
        .folder-sidebar {
            display: none;
        }
    }
</style>

<div class="row">
    <div class="col-lg-3 col-md-4 folder-sidebar">
        <div class="folder-tree">
            <div class="folder-tree-title">
                <i class="fas fa-folder-tree"></i> 文件夹
            </div>
            <ul class="folder-list" id="folderTree">
                <li class="folder-loading">
                    <i class="fas fa-spinner fa-spin"></i> 加载中...
                </li>
            </ul>
        </div>
    </div>

    <div class="col-lg-9 col-md-8">
        <div class="row mb-4">
            <div class="col">
                <h2><i class="fas fa-book"></i> 我的书籍</h2>
                <nav aria-label="breadcrumb" class="mt-2">
                    <ol class="breadcrumb mb-0" id="breadcrumb">
                    </ol>
                </nav>
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("AdvancedUser"))
            {
                <div class="col text-end">
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                        <i class="fas fa-upload"></i> 上传书籍
                    </button>
                </div>
            }
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <div class="input-group">
                    <input type="text" id="searchInput" class="form-control" placeholder="搜索书籍..." value="@searchKeyword" />
                    <button class="btn btn-outline-secondary" type="button" id="searchBtn">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="row">
            @foreach (var book in Model)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm file-card">
                        <div class="card-body text-center">
                            <i class="fas @(book.FileExtension.ToLower() == "pdf" ? "fa-file-pdf text-danger" : "fa-file-alt text-primary") fa-4x mb-3"></i>
                            <h6 class="card-title text-truncate" title="@book.FileName">@book.FileName</h6>
                            <p class="card-text small text-muted">
                                格式: @book.FileExtension.ToUpper()<br />
                                大小: @((book.FileSize / 1024).ToString("F2")) KB<br />
                                添加: @book.AddedTime.ToString("yyyy-MM-dd")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="d-grid gap-2">
                                <div class="btn-group w-100" role="group">
                                    <a href="@Url.Action("Play", "Media", new { id = book.FileId })" class="btn btn-sm btn-primary">
                                        <i class="fas fa-book-open"></i> 阅读
                                    </a>
                                    <a href="@Url.Action("Download", "Media", new { id = book.FileId })" class="btn btn-sm btn-success">
                                        <i class="fas fa-download"></i> 下载
                                    </a>
                                </div>
                                <div class="btn-group w-100" role="group">
                                    <button class="btn btn-sm btn-info favorite-btn" data-fileid="@book.FileId" onclick="toggleFavorite(@book.FileId, this)">
                                        <i class="fas fa-heart"></i> <span class="favorite-text">收藏</span>
                                    </button>
                                    <button class="btn btn-sm btn-warning" onclick="showAddToListModal(@book.FileId, 0)">
                                        <i class="fas fa-plus"></i> 加入列表
                                    </button>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <button class="btn btn-sm btn-danger" onclick="deleteFile(@book.FileId)">
                                            <i class="fas fa-trash"></i> 删除
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-book-open fa-4x text-muted mb-3"></i>
                <p class="text-muted">暂无书籍文件</p>
                @if (User.IsInRole("Admin") || User.IsInRole("AdvancedUser"))
                {
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                        <i class="fas fa-upload"></i> 上传第一本书籍
                    </button>
                }
            </div>
        }

        @if (totalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= totalPages && i <= 10; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Books", new { page = i, search = searchKeyword, folder = currentFolder })">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>

<!-- 添加到列表模态框 -->
<div class="modal fade" id="addToListModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-white">
                <h5 class="modal-title">添加到阅读列表</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">选择已有列表</label>
                    <select id="existingPlaylistSelect" class="form-select">
                        <option value="">-- 请选择 --</option>
                    </select>
                </div>
                <div class="text-center">或</div>
                <div class="mb-3 mt-2">
                    <label class="form-label">创建新列表</label>
                    <input type="text" id="newPlaylistName" class="form-control" placeholder="输入新列表名称" />
                </div>
                <div class="mb-3">
                    <label class="form-label">备注（可选）</label>
                    <textarea id="itemNote" class="form-control" rows="2" placeholder="添加备注信息..."></textarea>
                </div>
                <input type="hidden" id="currentFileId" />
                <input type="hidden" id="currentListType" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="addToSelectedList()">确定添加</button>
            </div>
        </div>
    </div>
</div>

<!-- 多文件上传模态框 -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-upload"></i> 上传书籍</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="uploadForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">选择文件（支持多选）</label>
                        <input type="file" id="fileInput" class="form-control" accept=".pdf,.txt" multiple />
                        <div class="form-text mt-2">
                            <i class="fas fa-info-circle"></i> 支持格式: PDF, TXT<br />
                            <i class="fas fa-weight-hanging"></i> 单个文件不超过500MB<br />
                            <i class="fas fa-layer-group"></i> 支持同时选择多个文件上传
                        </div>
                    </div>
                    <div id="fileList" class="mb-3 d-none">
                        <label class="form-label">已选择文件：</label>
                        <ul id="selectedFiles" class="list-group"></ul>
                    </div>
                    <div id="progressContainer" class="d-none">
                        <div class="progress mb-2">
                            <div id="uploadProgress" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%">0%</div>
                        </div>
                        <div id="uploadStatus" class="small text-muted">正在上传...</div>
                    </div>
                    <div id="uploadResult" class="mt-3 d-none">
                        <div class="alert alert-info"></div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="uploadBtn">
                    <i class="fas fa-cloud-upload-alt"></i> 上传
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currentFolder = '@currentFolder';
        var currentSearch = '@searchKeyword';
        var mediaType = 0;

        function navigateToFolder(folderPath) {
            var url = '/Media/Books?folder=' + encodeURIComponent(folderPath);
            if (currentSearch) {
                url += '&search=' + encodeURIComponent(currentSearch);
            }
            window.location.href = url;
        }

        function toggleFolder(element) {
            var subFolders = element.closest('li').querySelector('.sub-folders');
            if (subFolders) {
                subFolders.classList.toggle('expanded');
                element.classList.toggle('expanded');
            }
        }

        function renderFolderTree(treeData, containerId) {
            var container = document.getElementById(containerId);
            if (!container) return;

            var html = '<li class="folder-item ' + (currentFolder === '' ? 'active' : '') + '" onclick="navigateToFolder(\'\')">' +
                       '<span class="folder-toggle" style="visibility:hidden;">▶</span>' +
                       '<i class="fas fa-home folder-icon"></i>' +
                       '<span>全部文件</span>' +
                       '</li>';

            function renderNodes(nodes, depth) {
                var result = '';
                for (var i = 0; i < nodes.length; i++) {
                    var node = nodes[i];
                    var hasChildren = node.children && node.children.length > 0;
                    var isActive = currentFolder === node.relativePath;
                    var isParentActive = currentFolder && currentFolder.startsWith(node.relativePath + '/');
                    var shouldExpand = isParentActive || isActive;

                    result += '<li>';
                    result += '<div class="folder-item ' + (isActive ? 'active' : '') + '" onclick="navigateToFolder(\'' + node.relativePath + '\')">';
                    result += '<span class="folder-toggle ' + (shouldExpand ? 'expanded' : '') + '" onclick="event.stopPropagation(); toggleFolder(this)">';
                    if (hasChildren) {
                        result += '▶';
                    }
                    result += '</span>';
                    result += '<i class="fas fa-folder folder-icon"></i>';
                    result += '<span>' + node.name + '</span>';
                    result += '</div>';

                    if (hasChildren) {
                        result += '<ul class="sub-folders ' + (shouldExpand ? 'expanded' : '') + '">';
                        result += renderNodes(node.children, depth + 1);
                        result += '</ul>';
                    }
                    result += '</li>';
                }
                return result;
            }

            html += renderNodes(treeData, 0);
            container.innerHTML = html;
        }

        function renderBreadcrumb(currentFolder, containerId) {
            var container = document.getElementById(containerId);
            if (!container) return;

            var html = '<li class="breadcrumb-item folder-breadcrumb ' + (currentFolder === '' ? 'active' : '') + '">';
            if (currentFolder === '') {
                html += '全部文件';
            } else {
                html += '<a href="javascript:void(0)" style="text-decoration:none;" onclick="navigateToFolder(\'\')">全部文件</a>';
            }
            html += '</li>';

            if (currentFolder) {
                var parts = currentFolder.split('/').filter(Boolean);
                var cumulative = '';
                for (var i = 0; i < parts.length; i++) {
                    cumulative += (cumulative === '' ? '' : '/') + parts[i];
                    var isLast = i === parts.length - 1;
                    html += '<li class="breadcrumb-item folder-breadcrumb ' + (isLast ? 'active' : '') + '">';
                    if (isLast) {
                        html += parts[i];
                    } else {
                        html += '<a href="javascript:void(0)" style="text-decoration:none;" onclick="navigateToFolder(\'' + cumulative + '\')">' + parts[i] + '</a>';
                    }
                    html += '</li>';
                }
            }

            container.innerHTML = html;
        }

        $(document).ready(function() {
            $.get('/Media/GetFolderTree', { type: mediaType }, function(data) {
                renderFolderTree(data || [], 'folderTree');
            });

            renderBreadcrumb(currentFolder, 'breadcrumb');

            $('.favorite-btn').each(function() {
                var fileId = $(this).data('fileid');
                checkFavoriteStatus(fileId, $(this));
            });
        });

        function checkFavoriteStatus(fileId, btn) {
            $.get('/Favorite/Check', { fileId: fileId }, function(result) {
                if (result.isFavorited) {
                    updateFavoriteButton(btn, true);
                } else {
                    updateFavoriteButton(btn, false);
                }
            });
        }

        function updateFavoriteButton(btn, isFavorited) {
            if (isFavorited) {
                btn.html('<i class="fas fa-heart"></i> <span class="favorite-text">取消收藏</span>');
                btn.removeClass('btn-info').addClass('btn-danger');
            } else {
                btn.html('<i class="fas fa-heart"></i> <span class="favorite-text">收藏</span>');
                btn.removeClass('btn-danger').addClass('btn-info');
            }
            btn.data('favorited', isFavorited);
        }

        function toggleFavorite(fileId, btnElement) {
            var $btn = $(btnElement);
            var isFavorited = $btn.data('favorited');

            if (isFavorited) {
                $.ajax({
                    url: '/Favorite/Remove',
                    type: 'POST',
                    data: { fileId: fileId },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(result) {
                        if (result.success) {
                            updateFavoriteButton($btn, false);
                            alert('已取消收藏');
                        } else {
                            alert('操作失败：' + result.message);
                        }
                    },
                    error: function(xhr) {
                        alert('操作失败：' + (xhr.responseJSON?.message || '服务器错误'));
                    }
                });
            } else {
                $.ajax({
                    url: '/Favorite/Add',
                    type: 'POST',
                    data: { fileId: fileId },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(result) {
                        if (result.success) {
                            updateFavoriteButton($btn, true);
                            alert('已添加到收藏');
                        } else {
                            alert('操作失败：' + result.message);
                        }
                    },
                    error: function(xhr) {
                        alert('操作失败：' + (xhr.responseJSON?.message || '服务器错误'));
                    }
                });
            }
        }

        function deleteFile(fileId) {
            if (confirm('确定要删除这个文件吗？')) {
                $.post('/Media/Delete', { id: fileId }, function(result) {
                    if (result.success) location.reload();
                    else alert('删除失败：' + result.message);
                }).fail(function(xhr) {
                    alert('删除失败：' + (xhr.responseJSON?.message || '服务器错误'));
                });
            }
        }

        function showAddToListModal(fileId, type) {
            $('#currentFileId').val(fileId);
            $('#currentListType').val(type);
            $('#newPlaylistName').val('');
            $('#itemNote').val('');

            $.get('/Playlist/GetUserPlaylists', { type: type }, function(playlists) {
                var select = $('#existingPlaylistSelect');
                select.empty();
                select.append('<option value="">-- 请选择 --</option>');
                if (playlists && playlists.length > 0) {
                    for (var i = 0; i < playlists.length; i++) {
                        select.append('<option value="' + playlists[i].playlistId + '">' + playlists[i].playlistName + '</option>');
                    }
                }
            });

            new bootstrap.Modal(document.getElementById('addToListModal')).show();
        }

        function addToSelectedList() {
            var fileId = $('#currentFileId').val();
            var type = $('#currentListType').val();
            var existingPlaylistId = $('#existingPlaylistSelect').val();
            var newPlaylistName = $('#newPlaylistName').val().trim();
            var note = $('#itemNote').val();
            var token = $('input[name="__RequestVerificationToken"]').val();

            if (existingPlaylistId) {
                $.ajax({
                    url: '/Playlist/AddItem',
                    type: 'POST',
                    data: { playlistId: existingPlaylistId, fileId: fileId, note: note },
                    headers: { 'RequestVerificationToken': token },
                    success: function(result) {
                        if (result.success) {
                            alert('添加成功');
                            bootstrap.Modal.getInstance(document.getElementById('addToListModal')).hide();
                        } else {
                            alert('添加失败：' + result.message);
                        }
                    },
                    error: function(xhr) {
                        alert('添加失败：' + (xhr.responseJSON?.message || '服务器错误'));
                    }
                });
            } else if (newPlaylistName) {
                $.ajax({
                    url: '/Playlist/Create',
                    type: 'POST',
                    data: { name: newPlaylistName, description: '', type: type },
                    headers: { 'RequestVerificationToken': token },
                    success: function(result) {
                        if (result.success) {
                            $.ajax({
                                url: '/Playlist/AddItem',
                                type: 'POST',
                                data: { playlistId: result.playlistId, fileId: fileId, note: note },
                                headers: { 'RequestVerificationToken': token },
                                success: function(addResult) {
                                    if (addResult.success) {
                                        alert('已添加到新列表：' + newPlaylistName);
                                        bootstrap.Modal.getInstance(document.getElementById('addToListModal')).hide();
                                    } else {
                                        alert('添加失败：' + addResult.message);
                                    }
                                },
                                error: function(xhr) {
                                    alert('添加失败：' + (xhr.responseJSON?.message || '服务器错误'));
                                }
                            });
                        } else {
                            alert('创建列表失败：' + result.message);
                        }
                    },
                    error: function(xhr) {
                        alert('操作失败：' + (xhr.responseJSON?.message || '服务器错误'));
                    }
                });
            } else {
                alert('请选择已有列表或输入新列表名称');
            }
        }

        $('#fileInput').on('change', function() {
            var files = $(this)[0].files;
            var fileList = $('#selectedFiles');
            fileList.empty();

            if (files.length > 0) {
                $('#fileList').removeClass('d-none');
                for (var i = 0; i < files.length; i++) {
                    var file = files[i];
                    var fileSize = (file.size / 1024 / 1024).toFixed(2);
                    fileList.append('<li class="list-group-item d-flex justify-content-between align-items-center">' +
                        '<span><i class="fas fa-file-alt me-2"></i>' + file.name + '</span>' +
                        '<span class="badge bg-secondary rounded-pill">' + fileSize + ' MB</span>' +
                        '</li>');
                }
            } else {
                $('#fileList').addClass('d-none');
            }
        });

        $('#uploadBtn').on('click', function() {
            var files = $('#fileInput')[0].files;
            if (files.length === 0) {
                alert('请选择文件');
                return;
            }

            var formData = new FormData();
            for (var i = 0; i < files.length; i++) {
                formData.append('files', files[i]);
            }
            formData.append('mediaType', '0');

            $('#uploadResult').addClass('d-none');
            $('#progressContainer').removeClass('d-none');
            $('#uploadProgress').css('width', '0%').text('0%');
            $('#uploadStatus').text('正在上传...');

            $.ajax({
                url: '/Media/Upload',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                xhr: function() {
                    var xhr = new XMLHttpRequest();
                    xhr.upload.addEventListener('progress', function(e) {
                        if (e.lengthComputable) {
                            var percent = Math.round((e.loaded / e.total) * 100);
                            $('#uploadProgress').css('width', percent + '%').text(percent + '%');
                            $('#uploadStatus').text('上传进度: ' + percent + '%');
                        }
                    });
                    return xhr;
                },
                success: function(result) {
                    $('#progressContainer').addClass('d-none');
                    $('#uploadResult').removeClass('d-none');

                    if (result.success) {
                        $('#uploadResult .alert').removeClass('alert-danger').addClass('alert-success')
                            .html('<i class="fas fa-check-circle me-2"></i>' + result.message);
                        setTimeout(function() {
                            location.reload();
                        }, 2000);
                    } else {
                        $('#uploadResult .alert').removeClass('alert-success').addClass('alert-danger')
                            .html('<i class="fas fa-exclamation-circle me-2"></i>' + result.message);
                    }
                },
                error: function(xhr) {
                    $('#progressContainer').addClass('d-none');
                    $('#uploadResult').removeClass('d-none');
                    var errorMsg = xhr.responseJSON?.message || '上传失败，请稍后重试';
                    $('#uploadResult .alert').removeClass('alert-success').addClass('alert-danger')
                        .html('<i class="fas fa-exclamation-circle me-2"></i>' + errorMsg);
                }
            });
        });

        $('#searchBtn').click(function() {
            var keyword = $('#searchInput').val();
            var url = '/Media/Books?search=' + encodeURIComponent(keyword);
            if (currentFolder) {
                url += '&folder=' + encodeURIComponent(currentFolder);
            }
            location.href = url;
        });

        $('#searchInput').keypress(function(e) {
            if (e.which === 13) $('#searchBtn').click();
        });
    </script>
}
