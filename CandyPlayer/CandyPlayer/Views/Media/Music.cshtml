@model List<CandyPlayer.Models.MediaFile>
@using CandyPlayer.Services

@{
    ViewData["Title"] = "音乐库";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var searchKeyword = ViewBag.SearchKeyword as string ?? "";
    var currentFolder = ViewBag.CurrentFolder as string ?? "";
}

<style>
    .folder-tree {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 16px 0;
    }

    .folder-tree-title {
        padding: 0 16px 12px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 8px;
        font-weight: 600;
        color: var(--text-primary);
        font-size: 0.85rem;
    }

    .folder-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .folder-item {
        padding: 8px 16px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-secondary);
    }

    .folder-item:hover {
        background: rgba(99,102,241,0.1);
        color: #fff;
    }

    .folder-item.active {
        background: rgba(99,102,241,0.15);
        color: var(--primary-light);
    }

    .folder-item .folder-icon {
        color: #fbbf24;
    }

    .folder-item.active .folder-icon {
        color: var(--primary-light);
    }

    .folder-toggle {
        width: 16px;
        display: inline-flex;
        justify-content: center;
        transition: transform 0.2s;
    }

    .folder-toggle.expanded {
        transform: rotate(90deg);
    }

    .sub-folders {
        list-style: none;
        padding-left: 24px;
        margin: 0;
        display: none;
    }

    .sub-folders.expanded {
        display: block;
    }

    .breadcrumb-item {
        cursor: pointer;
        color: var(--text-secondary);
    }

    .breadcrumb-item:hover {
        color: var(--primary-light);
        text-decoration: underline;
    }

    .breadcrumb-item.active {
        color: var(--text-primary);
        cursor: default;
        text-decoration: none;
    }

    .file-card .folder-path {
        font-size: 11px;
        color: var(--text-secondary);
        margin-bottom: 4px;
    }

    .now-playing {
        animation: pulse-glow 2s ease-in-out infinite;
        border-color: rgba(99,102,241,0.3) !important;
    }

    @@keyframes pulse-glow {
        0%, 100% { box-shadow: 0 0 5px rgba(99,102,241,0.2); }
        50% { box-shadow: 0 0 20px rgba(99,102,241,0.4); }
    }

    .mode-btn.active-mode {
        background: rgba(99,102,241,0.2) !important;
        color: var(--primary-light) !important;
        font-weight: bold;
        border-color: rgba(99,102,241,0.3) !important;
    }

    .file-card {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .file-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.3), 0 0 20px rgba(99,102,241,0.1);
    }

    @@media (max-width: 991px) {
        .folder-sidebar {
            display: none;
        }
    }

    @@media (max-width: 576px) {
        .playback-controls .btn {
            padding: 0.4rem 0.6rem;
            font-size: 0.85rem;
        }

        .now-playing-title {
            font-size: 0.85rem;
        }
    }
</style>

<div class="row g-3">
    <div class="col-lg-3 col-md-4 folder-sidebar">
        <div class="folder-tree">
            <div class="folder-tree-title">
                <i class="fas fa-folder-tree"></i> 文件夹
            </div>
            <ul class="folder-list" id="folderTree">
                <li class="folder-item disabled">
                    <i class="fas fa-spinner fa-spin"></i>
                    <span>加载中...</span>
                </li>
            </ul>
        </div>
    </div>

    <div class="col-lg-9 col-md-8">
        <div class="row mb-4">
            <div class="col">
                <h2 style="font-size:1.5rem;"><i class="fas fa-music"></i> 音乐库</h2>
                <nav aria-label="breadcrumb" class="mt-2">
                    <ol class="breadcrumb mb-0 small" id="breadcrumb">
                    </ol>
                </nav>
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("AdvancedUser"))
            {
                <div class="col text-end">
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                        <i class="fas fa-upload"></i> <span class="d-none d-sm-inline">上传音乐</span>
                    </button>
                </div>
            }
        </div>

        <div class="row mb-3">
            <div class="col-12 col-md-6">
                <div class="input-group">
                    <input type="text" id="searchInput" class="form-control" placeholder="搜索音乐..." value="@searchKeyword" />
                    <button class="btn btn-outline-secondary" type="button" id="searchBtn">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- 播放器区域 -->
        <div class="card mb-4" style="background:rgba(99,102,241,0.08)!important;border-color:rgba(99,102,241,0.2)!important;">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <i class="fas fa-music me-2 now-playing" id="playingIcon" style="display:none;"></i>
                    <span class="now-playing-title text-truncate" id="currentSongTitle">未选择歌曲</span>
                </div>
                <audio id="audioPlayer" controls style="width: 100%;" class="bg-dark mb-3">
                    <source src="" type="audio/mpeg">
                    您的浏览器不支持音频播放
                </audio>
                <div class="d-flex justify-content-between align-items-center">
                    <div class="btn-group playback-controls">
                        <button class="btn btn-outline-light btn-sm" id="prevBtn" onclick="playPrev()" title="上一首">
                            <i class="fas fa-step-backward"></i>
                        </button>
                        <button class="btn btn-outline-light btn-sm" id="nextBtn" onclick="playNext()" title="下一首">
                            <i class="fas fa-step-forward"></i>
                        </button>
                    </div>
                    <div class="btn-group playback-controls flex-wrap">
                        <button class="btn btn-outline-light btn-sm mode-btn active-mode" data-mode="order" onclick="setPlayMode('order')">顺序</button>
                        <button class="btn btn-outline-light btn-sm mode-btn" data-mode="loop" onclick="setPlayMode('loop')">循环</button>
                        <button class="btn btn-outline-light btn-sm mode-btn" data-mode="single" onclick="setPlayMode('single')">单曲</button>
                        <button class="btn btn-outline-light btn-sm mode-btn" data-mode="random" onclick="setPlayMode('random')">随机</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            @foreach (var music in Model)
            {
                <div class="col-6 col-md-4 col-lg-3 mb-3">
                    <div class="card h-100 file-card" id="card-@music.FileId">
                        <div class="card-body text-center">
                            <i class="fas fa-music text-primary fa-4x mb-3"></i>
                            <h6 class="card-title text-truncate" title="@music.FileName">@music.FileName</h6>
                            <p class="card-text small text-muted">
                                格式: @music.FileExtension.ToUpper()<br />
                                大小: @((music.FileSize / 1024 / 1024).ToString("F2")) MB<br />
                                播放: @music.PlayCount 次
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="d-grid gap-2">
                                <div class="btn-group w-100" role="group">
                                    <button class="btn btn-sm btn-primary" onclick="playSong(@music.FileId, '@music.FileName.Replace("'", "\\'")')">
                                        <i class="fas fa-play"></i> 播放
                                    </button>
                                    <a href="@Url.Action("Download", "Media", new { id = music.FileId })" class="btn btn-sm btn-success">
                                        <i class="fas fa-download"></i> 下载
                                    </a>
                                </div>
                                <div class="btn-group w-100" role="group">
                                    <button class="btn btn-sm btn-info favorite-btn" data-fileid="@music.FileId" onclick="toggleFavorite(@music.FileId, this)">
                                        <i class="fas fa-heart"></i> <span class="favorite-text">收藏</span>
                                    </button>
                                    <button class="btn btn-sm btn-warning" onclick="showAddToListModal(@music.FileId, 1)">
                                        <i class="fas fa-plus"></i> 加入播放列表
                                    </button>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <button class="btn btn-sm btn-danger" onclick="deleteFile(@music.FileId)">
                                            <i class="fas fa-trash"></i> 删除
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-music fa-4x text-muted mb-3"></i>
                <p class="text-muted">暂无音乐文件</p>
                @if (User.IsInRole("Admin") || User.IsInRole("AdvancedUser"))
                {
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                        <i class="fas fa-upload"></i> 上传第一首音乐
                    </button>
                }
            </div>
        }

        @if (totalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= totalPages && i <= 10; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Music", new { page = i, search = searchKeyword, folder = currentFolder })">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>

<!-- 添加到列表模态框 -->
<div class="modal fade" id="addToListModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.08);">
                <h5 class="modal-title"><i class="fas fa-plus me-2" style="color:var(--primary-light);"></i>添加到播放列表</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">选择已有列表</label>
                    <select id="existingPlaylistSelect" class="form-select">
                        <option value="">-- 请选择 --</option>
                    </select>
                </div>
                <div class="text-center my-3" style="color:var(--text-secondary);font-size:0.85rem;">
                    <span style="border-top:1px solid rgba(255,255,255,0.08);display:inline-block;width:40px;vertical-align:middle;"></span>
                    <span class="mx-2">或</span>
                    <span style="border-top:1px solid rgba(255,255,255,0.08);display:inline-block;width:40px;vertical-align:middle;"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">创建新列表</label>
                    <input type="text" id="newPlaylistName" class="form-control" placeholder="输入新列表名称" />
                </div>
                <div class="mb-3">
                    <label class="form-label">备注（可选）</label>
                    <textarea id="itemNote" class="form-control" rows="2" placeholder="添加备注信息..."></textarea>
                </div>
                <input type="hidden" id="currentFileId" />
                <input type="hidden" id="currentListType" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="addToSelectedList()">
                    <i class="fas fa-check me-1"></i>确定添加
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 多文件上传模态框 -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.08);">
                <h5 class="modal-title"><i class="fas fa-upload"></i> 上传音乐</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="uploadForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">选择文件（支持多选）</label>
                        <input type="file" id="fileInput" class="form-control" accept=".mp3,.wav,.flac,.m4a" multiple />
                        <div class="form-text mt-2">
                            <i class="fas fa-info-circle"></i> 支持格式: MP3, WAV, FLAC, M4A<br />
                            <i class="fas fa-weight-hanging"></i> 单个文件不超过500MB<br />
                            <i class="fas fa-layer-group"></i> 支持同时选择多个文件上传
                        </div>
                    </div>
                    <div id="fileList" class="mb-3 d-none">
                        <label class="form-label">已选择文件：</label>
                        <ul id="selectedFiles" class="list-group"></ul>
                    </div>
                    <div id="progressContainer" class="d-none">
                        <div class="progress mb-2">
                            <div id="uploadProgress" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%">0%</div>
                        </div>
                        <div id="uploadStatus" class="small text-muted">正在上传...</div>
                    </div>
                    <div id="uploadResult" class="mt-3 d-none">
                        <div class="alert alert-info"></div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="uploadBtn">
                    <i class="fas fa-cloud-upload-alt"></i> 上传
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var audioPlayer = document.getElementById('audioPlayer');
        var currentPlayMode = localStorage.getItem('playMode') || 'order';
        var saveInterval;
        var currentFolder = '@currentFolder';
        var currentSearch = '@searchKeyword';

        var playlist = [];
        var currentIndex = -1;

        @foreach (var music in Model)
        {
            <text>playlist.push({ fileId: @music.FileId, fileName: '@music.FileName.Replace("'", "\\'")' });</text>
        }

        function navigateToFolder(folderPath) {
            var url = '/Media/Music?folder=' + encodeURIComponent(folderPath);
            if (currentSearch) {
                url += '&search=' + encodeURIComponent(currentSearch);
            }
            window.location.href = url;
        }

        function toggleFolder(element) {
            var subFolders = element.closest('.folder-item').nextElementSibling;
            if (subFolders && subFolders.classList.contains('sub-folders')) {
                subFolders.classList.toggle('expanded');
                element.classList.toggle('expanded');
            }
        }

        function renderFolderTree(treeData, containerId) {
            var container = document.getElementById(containerId);
            if (!container) return;

            var html = '';

            html += '<li class="folder-item ' + (currentFolder === '' ? 'active' : '') + '" onclick="navigateToFolder(\'\')">';
            html += '    <span class="folder-toggle" style="visibility: hidden;">▶</span>';
            html += '    <i class="fas fa-home folder-icon"></i>';
            html += '    <span>全部文件</span>';
            html += '</li>';

            function renderNodes(nodes) {
                var result = '';
                for (var i = 0; i < nodes.length; i++) {
                    var node = nodes[i];
                    var isActive = currentFolder === node.relativePath;
                    var isParentActive = currentFolder !== '' && currentFolder.startsWith(node.relativePath + '/');
                    var hasChildren = node.children && node.children.length > 0;

                    result += '<li>';
                    result += '    <div class="folder-item ' + (isActive ? 'active' : '') + '" onclick="navigateToFolder(\'' + node.relativePath.replace(/'/g, "\\'") + '\')">';
                    result += '        <span class="folder-toggle ' + ((isParentActive || isActive) ? 'expanded' : '') + '" onclick="event.stopPropagation(); toggleFolder(this)">';
                    if (hasChildren) {
                        result += '            <span>▶</span>';
                    }
                    result += '        </span>';
                    result += '        <i class="fas fa-folder folder-icon"></i>';
                    result += '        <span>' + node.name + '</span>';
                    result += '    </div>';
                    if (hasChildren) {
                        result += '    <ul class="sub-folders ' + ((isParentActive || isActive) ? 'expanded' : '') + '">';
                        result += renderNodes(node.children);
                        result += '    </ul>';
                    }
                    result += '</li>';
                }
                return result;
            }

            html += renderNodes(treeData);
            container.innerHTML = html;
        }

        function renderBreadcrumb(currentFolder, containerId) {
            var container = document.getElementById(containerId);
            if (!container) return;

            var html = '';

            html += '<li class="breadcrumb-item ' + (currentFolder === '' ? 'active' : '') + '" onclick="navigateToFolder(\'\')">';
            html += '    <a href="javascript:void(0)" style="text-decoration: none;">全部文件</a>';
            html += '</li>';

            if (currentFolder && currentFolder !== '') {
                var pathParts = currentFolder.split('/').filter(function(p) { return p !== ''; });
                var cumulativePath = '';
                for (var i = 0; i < pathParts.length; i++) {
                    cumulativePath += (cumulativePath === '' ? '' : '/') + pathParts[i];
                    var isLast = i === pathParts.length - 1;
                    html += '<li class="breadcrumb-item ' + (isLast ? 'active' : '') + '">';
                    if (isLast) {
                        html += pathParts[i];
                    } else {
                        html += '<a href="javascript:void(0)" onclick="navigateToFolder(\'' + cumulativePath.replace(/'/g, "\\'") + '\')" style="text-decoration: none;">' + pathParts[i] + '</a>';
                    }
                    html += '</li>';
                }
            }

            container.innerHTML = html;
        }

        function playSong(fileId, fileName) {
            var idx = playlist.findIndex(function(s) { return s.fileId === fileId; });
            if (idx !== -1) {
                currentIndex = idx;
            }

            document.getElementById('currentSongTitle').innerText = fileName;
            document.getElementById('playingIcon').style.display = 'inline';
            audioPlayer.src = '/Media/Stream/' + fileId;
            audioPlayer.play();

            updateCardHighlight(fileId);
        }

        function playPrev() {
            if (playlist.length === 0) return;

            if (currentPlayMode === 'random') {
                currentIndex = Math.floor(Math.random() * playlist.length);
            } else {
                currentIndex = (currentIndex - 1 + playlist.length) % playlist.length;
            }

            var song = playlist[currentIndex];
            playSong(song.fileId, song.fileName);
        }

        function playNext() {
            if (playlist.length === 0) return;

            if (currentPlayMode === 'random') {
                currentIndex = Math.floor(Math.random() * playlist.length);
            } else {
                currentIndex = (currentIndex + 1) % playlist.length;
            }

            var song = playlist[currentIndex];
            playSong(song.fileId, song.fileName);
        }

        function setPlayMode(mode) {
            currentPlayMode = mode;
            localStorage.setItem('playMode', mode);

            document.querySelectorAll('.mode-btn').forEach(function(btn) {
                btn.classList.remove('active-mode');
            });
            document.querySelector('.mode-btn[data-mode="' + mode + '"]').classList.add('active-mode');

            var modeName = mode === 'order' ? '顺序播放' : (mode === 'loop' ? '列表循环' : (mode === 'single' ? '单曲循环' : '随机播放'));
            if (typeof showToast === 'function') {
                showToast('播放模式：' + modeName, 'info');
            }
        }

        function updateCardHighlight(fileId) {
            document.querySelectorAll('.file-card').forEach(function(card) {
                card.classList.remove('border-primary', 'now-playing');
            });
            var activeCard = document.getElementById('card-' + fileId);
            if (activeCard) {
                activeCard.classList.add('border-primary', 'now-playing');
            }
        }

        $(document).ready(function() {
            $.get('/Media/GetFolderTree', { type: 1 }, function(data) {
                renderFolderTree(data || [], 'folderTree');
            });

            renderBreadcrumb(currentFolder, 'breadcrumb');

            $('.favorite-btn').each(function() {
                var fileId = $(this).data('fileid');
                checkFavoriteStatus(fileId, $(this));
            });

            setPlayMode(currentPlayMode);
        });

        function checkFavoriteStatus(fileId, btn) {
            $.get('/Favorite/Check', { fileId: fileId }, function(result) {
                if (result.isFavorited) {
                    updateFavoriteButton(btn, true);
                } else {
                    updateFavoriteButton(btn, false);
                }
            });
        }

        function updateFavoriteButton(btn, isFavorited) {
            if (isFavorited) {
                btn.html('<i class="fas fa-heart"></i> <span class="favorite-text">取消收藏</span>');
                btn.removeClass('btn-info').addClass('btn-danger');
            } else {
                btn.html('<i class="fas fa-heart"></i> <span class="favorite-text">收藏</span>');
                btn.removeClass('btn-danger').addClass('btn-info');
            }
            btn.data('favorited', isFavorited);
        }

        function toggleFavorite(fileId, btnElement) {
            var $btn = $(btnElement);
            var isFavorited = $btn.data('favorited');

            if (isFavorited) {
                $.ajax({
                    url: '/Favorite/Remove',
                    type: 'POST',
                    data: { fileId: fileId },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(result) {
                        if (result.success) {
                            updateFavoriteButton($btn, false);
                            if (typeof showToast === 'function') showToast('已取消收藏', 'success');
                        } else {
                            if (typeof showToast === 'function') showToast(result.message || '操作失败', 'error');
                        }
                    },
                    error: function(xhr) {
                        if (typeof showToast === 'function') showToast('操作失败', 'error');
                    }
                });
            } else {
                $.ajax({
                    url: '/Favorite/Add',
                    type: 'POST',
                    data: { fileId: fileId },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(result) {
                        if (result.success) {
                            updateFavoriteButton($btn, true);
                            if (typeof showToast === 'function') showToast('已添加到收藏', 'success');
                        } else {
                            if (typeof showToast === 'function') showToast(result.message || '操作失败', 'error');
                        }
                    },
                    error: function(xhr) {
                        if (typeof showToast === 'function') showToast('操作失败', 'error');
                    }
                });
            }
        }

        function deleteFile(fileId) {
            if (confirm('确定要删除这个音乐文件吗？')) {
                $.post('/Media/Delete', { id: fileId }, function(result) {
                    if (result.success) location.reload();
                    else if (typeof showToast === 'function') showToast('删除失败：' + result.message, 'error');
                }).fail(function(xhr) {
                    if (typeof showToast === 'function') showToast('删除失败', 'error');
                });
            }
        }

        function showAddToListModal(fileId, type) {
            $('#currentFileId').val(fileId);
            $('#currentListType').val(type);
            $('#newPlaylistName').val('');
            $('#itemNote').val('');

            $.get('/Playlist/GetUserPlaylists', { type: type }, function(playlists) {
                var select = $('#existingPlaylistSelect');
                select.empty();
                select.append('<option value="">-- 请选择 --</option>');
                if (playlists && playlists.length > 0) {
                    for (var i = 0; i < playlists.length; i++) {
                        select.append('<option value="' + playlists[i].playlistId + '">' + playlists[i].playlistName + '</option>');
                    }
                }
            });

            new bootstrap.Modal(document.getElementById('addToListModal')).show();
        }

        function addToSelectedList() {
            var fileId = $('#currentFileId').val();
            var type = $('#currentListType').val();
            var existingPlaylistId = $('#existingPlaylistSelect').val();
            var newPlaylistName = $('#newPlaylistName').val().trim();
            var note = $('#itemNote').val();
            var token = $('input[name="__RequestVerificationToken"]').val();

            if (existingPlaylistId) {
                $.ajax({
                    url: '/Playlist/AddItem',
                    type: 'POST',
                    data: { playlistId: existingPlaylistId, fileId: fileId, note: note },
                    headers: { 'RequestVerificationToken': token },
                    success: function(result) {
                        if (result.success) {
                            if (typeof showToast === 'function') showToast('添加成功', 'success');
                            bootstrap.Modal.getInstance(document.getElementById('addToListModal')).hide();
                        } else {
                            if (typeof showToast === 'function') showToast(result.message || '添加失败', 'error');
                        }
                    },
                    error: function(xhr) {
                        if (typeof showToast === 'function') showToast('添加失败', 'error');
                    }
                });
            } else if (newPlaylistName) {
                $.ajax({
                    url: '/Playlist/Create',
                    type: 'POST',
                    data: { name: newPlaylistName, description: '', type: type },
                    headers: { 'RequestVerificationToken': token },
                    success: function(result) {
                        if (result.success) {
                            $.ajax({
                                url: '/Playlist/AddItem',
                                type: 'POST',
                                data: { playlistId: result.playlistId, fileId: fileId, note: note },
                                headers: { 'RequestVerificationToken': token },
                                success: function(addResult) {
                                    if (addResult.success) {
                                        if (typeof showToast === 'function') showToast('已添加到新列表：' + newPlaylistName, 'success');
                                        bootstrap.Modal.getInstance(document.getElementById('addToListModal')).hide();
                                    } else {
                                        if (typeof showToast === 'function') showToast(addResult.message || '添加失败', 'error');
                                    }
                                },
                                error: function(xhr) {
                                    if (typeof showToast === 'function') showToast('添加失败', 'error');
                                }
                            });
                        } else {
                            if (typeof showToast === 'function') showToast(result.message || '创建列表失败', 'error');
                        }
                    },
                    error: function(xhr) {
                        if (typeof showToast === 'function') showToast('操作失败', 'error');
                    }
                });
            } else {
                if (typeof showToast === 'function') showToast('请选择已有列表或输入新列表名称', 'warning');
            }
        }

        $('#fileInput').on('change', function() {
            var files = $(this)[0].files;
            var fileList = $('#selectedFiles');
            fileList.empty();

            if (files.length > 0) {
                $('#fileList').removeClass('d-none');
                for (var i = 0; i < files.length; i++) {
                    var file = files[i];
                    var fileSize = (file.size / 1024 / 1024).toFixed(2);
                    fileList.append('<li class="list-group-item d-flex justify-content-between align-items-center">' +
                        '<span><i class="fas fa-music me-2"></i>' + file.name + '</span>' +
                        '<span class="badge bg-secondary rounded-pill">' + fileSize + ' MB</span>' +
                        '</li>');
                }
            } else {
                $('#fileList').addClass('d-none');
            }
        });

        $('#uploadBtn').on('click', function() {
            var files = $('#fileInput')[0].files;
            if (files.length === 0) {
                if (typeof showToast === 'function') showToast('请选择文件', 'warning');
                return;
            }

            var formData = new FormData();
            for (var i = 0; i < files.length; i++) {
                formData.append('files', files[i]);
            }
            formData.append('mediaType', '1');

            $('#uploadResult').addClass('d-none');
            $('#progressContainer').removeClass('d-none');
            $('#uploadProgress').css('width', '0%').text('0%');
            $('#uploadStatus').text('正在上传...');

            $.ajax({
                url: '/Media/Upload',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                xhr: function() {
                    var xhr = new XMLHttpRequest();
                    xhr.upload.addEventListener('progress', function(e) {
                        if (e.lengthComputable) {
                            var percent = Math.round((e.loaded / e.total) * 100);
                            $('#uploadProgress').css('width', percent + '%').text(percent + '%');
                            $('#uploadStatus').text('上传进度: ' + percent + '%');
                        }
                    });
                    return xhr;
                },
                success: function(result) {
                    $('#progressContainer').addClass('d-none');
                    $('#uploadResult').removeClass('d-none');

                    if (result.success) {
                        $('#uploadResult .alert').removeClass('alert-danger').addClass('alert-success')
                            .html('<i class="fas fa-check-circle me-2"></i>' + result.message);
                        setTimeout(function() {
                            location.reload();
                        }, 2000);
                    } else {
                        $('#uploadResult .alert').removeClass('alert-success').addClass('alert-danger')
                            .html('<i class="fas fa-exclamation-circle me-2"></i>' + result.message);
                    }
                },
                error: function(xhr) {
                    $('#progressContainer').addClass('d-none');
                    $('#uploadResult').removeClass('d-none');
                    var errorMsg = xhr.responseJSON?.message || '上传失败，请稍后重试';
                    $('#uploadResult .alert').removeClass('alert-success').addClass('alert-danger')
                        .html('<i class="fas fa-exclamation-circle me-2"></i>' + errorMsg);
                }
            });
        });

        audioPlayer.addEventListener('ended', function() {
            document.getElementById('playingIcon').style.display = 'none';

            if (currentPlayMode === 'single') {
                audioPlayer.currentTime = 0;
                audioPlayer.play();
                document.getElementById('playingIcon').style.display = 'inline';
            } else if (currentPlayMode === 'loop') {
                playNext();
            } else if (currentPlayMode === 'random') {
                playNext();
            } else {
                if (currentIndex < playlist.length - 1) {
                    playNext();
                }
            }
        });

        audioPlayer.addEventListener('play', function() {
            document.getElementById('playingIcon').style.display = 'inline';
        });

        audioPlayer.addEventListener('pause', function() {
            document.getElementById('playingIcon').style.display = 'none';
        });

        $('#searchBtn').click(function() {
            var keyword = $('#searchInput').val();
            var url = '/Media/Music?search=' + encodeURIComponent(keyword);
            if (currentFolder) {
                url += '&folder=' + encodeURIComponent(currentFolder);
            }
            location.href = url;
        });

        $('#searchInput').keypress(function(e) {
            if (e.which === 13) $('#searchBtn').click();
        });

        document.addEventListener('keydown', function(e) {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

            switch(e.key) {
                case 'ArrowLeft':
                    e.preventDefault();
                    audioPlayer.currentTime = Math.max(0, audioPlayer.currentTime - 5);
                    break;
                case 'ArrowRight':
                    e.preventDefault();
                    audioPlayer.currentTime = Math.min(audioPlayer.duration, audioPlayer.currentTime + 5);
                    break;
                case ' ':
                    e.preventDefault();
                    if (audioPlayer.paused) audioPlayer.play();
                    else audioPlayer.pause();
                    break;
                case 'ArrowUp':
                    e.preventDefault();
                    audioPlayer.volume = Math.min(1, audioPlayer.volume + 0.1);
                    break;
                case 'ArrowDown':
                    e.preventDefault();
                    audioPlayer.volume = Math.max(0, audioPlayer.volume - 0.1);
                    break;
            }
        });
    </script>
}
