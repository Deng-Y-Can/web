@model CandyPlayer.Models.Playlist

@{
    ViewData["Title"] = Model.PlaylistName + " - 详情";
    var typeName = Model.Type == CandyPlayer.Models.PlaylistType.Book ? "阅读列表" : (Model.Type == CandyPlayer.Models.PlaylistType.Music ? "播放列表" : "观看列表");
    var typeIcon = Model.Type == CandyPlayer.Models.PlaylistType.Book ? "fa-book" : (Model.Type == CandyPlayer.Models.PlaylistType.Music ? "fa-music" : "fa-video");
    var returnUrl = Model.Type == CandyPlayer.Models.PlaylistType.Book ? "/Playlist/Books" : (Model.Type == CandyPlayer.Models.PlaylistType.Music ? "/Playlist/Music" : "/Playlist/Videos");
    var items = Model.PlaylistItems.Where(i => i.MediaFile != null).OrderBy(i => i.SortOrder).ToList();
}

<style>
    .detail-header {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 24px;
    }

    .detail-header .header-bg {
        height: 120px;
        background: linear-gradient(135deg, rgba(99,102,241,0.2), rgba(244,114,182,0.1));
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .detail-header .header-bg i {
        font-size: 3rem;
        opacity: 0.2;
    }

    .detail-header .header-content {
        padding: 20px;
    }

    .detail-header h2 {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .detail-header .meta {
        font-size: 0.8rem;
        color: var(--text-secondary);
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .detail-header .meta span {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .item-card {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        border-radius: 12px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 8px;
        transition: all 0.3s ease;
        gap: 12px;
    }

    .item-card:hover {
        background: rgba(99,102,241,0.06);
        border-color: rgba(99,102,241,0.15);
        transform: translateX(4px);
    }

    .item-card .item-index {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: rgba(99,102,241,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--primary-light);
        flex-shrink: 0;
    }

    .item-card .item-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .item-card .item-info {
        flex: 1;
        min-width: 0;
    }

    .item-card .item-info h6 {
        font-size: 0.85rem;
        font-weight: 500;
        margin-bottom: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .item-card .item-info .item-meta {
        font-size: 0.7rem;
        color: var(--text-secondary);
        display: flex;
        gap: 8px;
    }

    .item-card .item-note {
        font-size: 0.75rem;
        color: var(--text-secondary);
        font-style: italic;
        max-width: 150px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .item-card .item-actions {
        display: flex;
        gap: 4px;
        flex-shrink: 0;
    }

    .item-card .item-actions .btn {
        width: 32px;
        height: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-size: 0.75rem;
    }

    .empty-items {
        text-align: center;
        padding: 40px 20px;
    }

    .empty-items i {
        font-size: 3rem;
        opacity: 0.2;
        margin-bottom: 12px;
    }

    .empty-items p {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    @@media (max-width: 576px) {
        .item-card .item-note {
            display: none;
        }

        .item-card .item-meta {
            display: none;
        }
    }
</style>

<div class="fade-in-up">
    <!-- 头部信息 -->
    <div class="detail-header">
        <div class="header-bg">
            <i class="fas @typeIcon" style="color:var(--primary-light);"></i>
        </div>
        <div class="header-content">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <h2><i class="fas @typeIcon me-2" style="color:var(--primary-light);"></i>@Model.PlaylistName</h2>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="text-muted small mb-2">@Model.Description</p>
                    }
                    <div class="meta">
                        <span><i class="fas fa-calendar"></i> @Model.CreatedAt.ToString("yyyy-MM-dd")</span>
                        <span><i class="fas fa-list"></i> 共 @items.Count 项</span>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <span><i class="fas fa-sync"></i> 更新于 @Model.UpdatedAt.Value.ToString("MM-dd HH:mm")</span>
                        }
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    @if (items.Any())
                    {
                        <button class="btn btn-sm btn-primary" onclick="playAll()">
                            <i class="fas fa-play me-1"></i>播放全部
                        </button>
                    }
                    <button class="btn btn-sm btn-success" onclick="showAddItemModal()">
                        <i class="fas fa-plus me-1"></i>添加
                    </button>
                    <a href="@returnUrl" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i>返回
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- 项目列表 -->
    @if (items.Any())
    {
        <div id="itemList">
            @{
                int index = 1;
            }
            @foreach (var item in items)
            {
                var file = item.MediaFile;
                <div class="item-card" data-file-id="@file.FileId">
                    <div class="item-index">@index</div>
                    <div class="item-icon" style="background:@(file.MediaType == CandyPlayer.Models.MediaType.Music ? "rgba(99,102,241,0.1)" : file.MediaType == CandyPlayer.Models.MediaType.Video ? "rgba(248,113,113,0.1)" : "rgba(52,211,153,0.1)");color:@(file.MediaType == CandyPlayer.Models.MediaType.Music ? "var(--primary-light)" : file.MediaType == CandyPlayer.Models.MediaType.Video ? "#f87171" : "var(--accent2)");">
                        @if (file.MediaType == CandyPlayer.Models.MediaType.Music)
                        {
                            <i class="fas fa-music"></i>
                        }
                        else if (file.MediaType == CandyPlayer.Models.MediaType.Video)
                        {
                            <i class="fas fa-video"></i>
                        }
                        else
                        {
                            <i class="fas fa-book"></i>
                        }
                    </div>
                    <div class="item-info">
                        <h6>@file.FileName</h6>
                        <div class="item-meta">
                            <span>@file.FileExtension.ToUpper()</span>
                            <span>@(file.FileSize / 1024 / 1024) MB</span>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(item.Note))
                    {
                        <div class="item-note" title="@item.Note">
                            <i class="fas fa-sticky-note me-1"></i>@item.Note
                        </div>
                    }
                    <div class="item-actions">
                        <a href="@Url.Action("Play", "Media", new { id = file.FileId })" class="btn btn-primary" title="播放">
                            <i class="fas fa-play"></i>
                        </a>
                        <button class="btn btn-outline-secondary" onclick="editNote(@file.FileId, '@(item.Note?.Replace("'", "\\'") ?? "")')" title="编辑备注">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn btn-outline-danger" onclick="removeItem(@file.FileId)" title="移除">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
                index++;
            }
        </div>
    }
    else
    {
        <div class="empty-items">
            <i class="fas @typeIcon" style="color:var(--primary-light);"></i>
            <p>列表为空</p>
            <button class="btn btn-sm btn-primary" onclick="showAddItemModal()">
                <i class="fas fa-plus me-1"></i>添加第一个项目
            </button>
        </div>
    }
</div>

<!-- 添加项目模态框 -->
<div class="modal fade" id="addItemModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.08);">
                <h5 class="modal-title">添加项目到 @Model.PlaylistName</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addItemForm">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">选择文件</label>
                        <select id="fileSelect" class="form-select" required>
                            <option value="">请选择...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">备注（可选）</label>
                        <textarea id="itemNote" class="form-control" rows="2" placeholder="添加备注信息..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="addItem()">添加</button>
            </div>
        </div>
    </div>
</div>

<!-- 编辑备注模态框 -->
<div class="modal fade" id="editNoteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.08);">
                <h5 class="modal-title">编辑备注</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <textarea id="editNoteContent" class="form-control" rows="3"></textarea>
                <input type="hidden" id="editFileId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="saveNote()">保存</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var playlistId = @Model.PlaylistId;
        var playlistType = @((int)Model.Type);

        function showAddItemModal() {
            $.get('/Media/GetAvailableFiles', { type: playlistType, excludePlaylistId: playlistId }, function(files) {
                var select = $('#fileSelect');
                select.empty();
                select.append('<option value="">请选择...</option>');
                if (files && files.length > 0) {
                    for (var i = 0; i < files.length; i++) {
                        var file = files[i];
                        select.append('<option value="' + file.fileId + '">' + file.fileName + ' (' + (file.fileSize / 1024 / 1024).toFixed(2) + ' MB)</option>');
                    }
                } else {
                    select.append('<option value="" disabled>没有可添加的文件</option>');
                }
                new bootstrap.Modal(document.getElementById('addItemModal')).show();
            });
        }

        function addItem() {
            var fileId = $('#fileSelect').val();
            var note = $('#itemNote').val();
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            if (!fileId) {
                if (typeof showToast === 'function') showToast('请选择文件', 'warning');
                return;
            }

            $.post('/Playlist/AddItem', { playlistId: playlistId, fileId: fileId, note: note }, function(result) {
                if (result.success) {
                    if (typeof showToast === 'function') showToast('添加成功', 'success');
                    setTimeout(function() { location.reload(); }, 800);
                } else {
                    if (typeof showToast === 'function') showToast(result.message || '添加失败', 'error');
                    else alert(result.message || '添加失败');
                }
            }).fail(function() {
                if (typeof showToast === 'function') showToast('添加失败', 'error');
                else alert('添加失败');
            });
        }

        function removeItem(fileId) {
            if (confirm('确定要从列表中移除这个项目吗？')) {
                $.post('/Playlist/RemoveItem', { playlistId: playlistId, fileId: fileId }, function(result) {
                    if (result.success) {
                        var card = document.querySelector('[data-file-id="' + fileId + '"]');
                        if (card) {
                            card.style.transition = 'all 0.4s ease';
                            card.style.opacity = '0';
                            card.style.transform = 'translateX(30px)';
                            setTimeout(function() { card.remove(); }, 400);
                        }
                        if (typeof showToast === 'function') showToast('已移除', 'success');
                    } else {
                        if (typeof showToast === 'function') showToast(result.message || '移除失败', 'error');
                        else alert(result.message || '移除失败');
                    }
                });
            }
        }

        function editNote(fileId, currentNote) {
            $('#editFileId').val(fileId);
            $('#editNoteContent').val(currentNote);
            new bootstrap.Modal(document.getElementById('editNoteModal')).show();
        }

        function saveNote() {
            var fileId = $('#editFileId').val();
            var note = $('#editNoteContent').val();

            $.post('/Playlist/UpdateItemNote', { playlistId: playlistId, fileId: fileId, note: note }, function(result) {
                if (result.success) {
                    if (typeof showToast === 'function') showToast('备注已更新', 'success');
                    setTimeout(function() { location.reload(); }, 800);
                } else {
                    if (typeof showToast === 'function') showToast(result.message || '更新失败', 'error');
                    else alert(result.message || '更新失败');
                }
            });
        }

        function playAll() {
            window.location.href = '/Playlist/PlayAll/' + playlistId;
        }
    </script>
}
