@{
    ViewData["Title"] = "首页";
}

<style>
    .stat-card {
        position: relative;
        overflow: hidden;
        border-radius: 16px !important;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        transition: all 0.5s ease;
    }

    .stat-card:hover::before {
        transform: scale(1.5);
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 3rem;
        opacity: 0.15;
    }

    .stat-card h5 {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.8;
        margin-bottom: 4px;
    }

    .stat-card h2 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
    }

    .section-card {
        border-radius: 16px !important;
        overflow: hidden;
    }

    .section-card .card-header {
        border-bottom: 1px solid rgba(255,255,255,0.05) !important;
        padding: 1rem 1.25rem;
    }

    .section-card .card-header h5 {
        font-size: 0.9rem;
        font-weight: 600;
        margin: 0;
    }

    .media-item {
        padding: 0.7rem 1rem;
        border-radius: 10px;
        margin-bottom: 4px;
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }

    .media-item:hover {
        background: rgba(99,102,241,0.08) !important;
        border-color: rgba(99,102,241,0.15);
        transform: translateX(4px);
    }

    .media-item .item-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    @@media (max-width: 576px) {
        .stat-card h2 {
            font-size: 1.5rem;
        }
        .stat-card .stat-icon {
            font-size: 2rem;
        }
    }
</style>

<div class="fade-in-up">
    <div class="row mb-4">
        <div class="col">
            <h2 style="font-size:1.5rem;font-weight:700;">
                <i class="fas fa-tachometer-alt me-2" style="color:var(--primary-light);"></i>欢迎回来，@User.Identity?.Name
            </h2>
            <p class="text-muted small">这是您的个人媒体中心</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card stat-card" style="background:linear-gradient(135deg,rgba(99,102,241,0.15),rgba(99,102,241,0.05))!important;border-color:rgba(99,102,241,0.2)!important;">
                <div class="card-body">
                    <i class="fas fa-files stat-icon" style="color:var(--primary-light);"></i>
                    <h5>总文件数</h5>
                    <h2 style="color:var(--primary-light);">@ViewBag.TotalFiles</h2>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-card" style="background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(16,185,129,0.05))!important;border-color:rgba(16,185,129,0.2)!important;">
                <div class="card-body">
                    <i class="fas fa-book stat-icon" style="color:var(--accent2);"></i>
                    <h5>书籍</h5>
                    <h2 style="color:var(--accent2);">@ViewBag.BookCount</h2>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-card" style="background:linear-gradient(135deg,rgba(244,114,182,0.15),rgba(244,114,182,0.05))!important;border-color:rgba(244,114,182,0.2)!important;">
                <div class="card-body">
                    <i class="fas fa-music stat-icon" style="color:var(--accent);"></i>
                    <h5>音乐</h5>
                    <h2 style="color:var(--accent);">@ViewBag.MusicCount</h2>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-card" style="background:linear-gradient(135deg,rgba(251,191,36,0.15),rgba(251,191,36,0.05))!important;border-color:rgba(251,191,36,0.2)!important;">
                <div class="card-body">
                    <i class="fas fa-video stat-icon" style="color:#fbbf24;"></i>
                    <h5>视频</h5>
                    <h2 style="color:#fbbf24;">@ViewBag.VideoCount</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6 mb-4">
            <div class="card section-card h-100">
                <div class="card-header d-flex align-items-center">
                    <div style="width:4px;height:20px;background:linear-gradient(180deg,var(--primary),var(--accent));border-radius:2px;margin-right:10px;"></div>
                    <h5><i class="fas fa-chart-line me-2" style="color:var(--primary-light);"></i>热门文件</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.TopFiles != null && ((List<CandyPlayer.Models.MediaFile>)ViewBag.TopFiles).Any())
                    {
                        @foreach (var file in ViewBag.TopFiles as List<CandyPlayer.Models.MediaFile>)
                        {
                            <a href="@Url.Action("Play", "Media", new { id = file.FileId })" class="media-item d-flex justify-content-between align-items-center text-decoration-none">
                                <div class="d-flex align-items-center">
                                    <div class="item-icon me-3" style="background:rgba(99,102,241,0.1);">
                                        @if (file.MediaType == CandyPlayer.Models.MediaType.Music)
                                        {
                                            <i class="fas fa-music" style="color:var(--accent);font-size:0.85rem;"></i>
                                        }
                                        else if (file.MediaType == CandyPlayer.Models.MediaType.Video)
                                        {
                                            <i class="fas fa-video" style="color:#f87171;font-size:0.85rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-book" style="color:var(--accent2);font-size:0.85rem;"></i>
                                        }
                                    </div>
                                    <span class="text-truncate" style="max-width:200px;font-size:0.9rem;">@file.FileName</span>
                                </div>
                                <span style="font-size:0.75rem;padding:3px 10px;background:rgba(99,102,241,0.1);border-radius:20px;color:var(--primary-light);white-space:nowrap;">@file.PlayCount 次</span>
                            </a>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-4" style="font-size:0.9rem;">暂无数据</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card section-card h-100">
                <div class="card-header d-flex align-items-center">
                    <div style="width:4px;height:20px;background:linear-gradient(180deg,var(--accent2),#10b981);border-radius:2px;margin-right:10px;"></div>
                    <h5><i class="fas fa-clock me-2" style="color:var(--accent2);"></i>最近添加</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.RecentFiles != null && ((List<CandyPlayer.Models.MediaFile>)ViewBag.RecentFiles).Any())
                    {
                        @foreach (var file in ViewBag.RecentFiles as List<CandyPlayer.Models.MediaFile>)
                        {
                            <a href="@Url.Action("Play", "Media", new { id = file.FileId })" class="media-item d-flex justify-content-between align-items-center text-decoration-none">
                                <div class="d-flex align-items-center">
                                    <div class="item-icon me-3" style="background:rgba(16,185,129,0.1);">
                                        @if (file.MediaType == CandyPlayer.Models.MediaType.Music)
                                        {
                                            <i class="fas fa-music" style="color:var(--accent);font-size:0.85rem;"></i>
                                        }
                                        else if (file.MediaType == CandyPlayer.Models.MediaType.Video)
                                        {
                                            <i class="fas fa-video" style="color:#f87171;font-size:0.85rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-book" style="color:var(--accent2);font-size:0.85rem;"></i>
                                        }
                                    </div>
                                    <span class="text-truncate" style="max-width:180px;font-size:0.9rem;">@file.FileName</span>
                                </div>
                                <span style="font-size:0.75rem;color:var(--text-secondary);white-space:nowrap;">@file.AddedTime.ToString("MM-dd")</span>
                            </a>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-4" style="font-size:0.9rem;">暂无数据</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
