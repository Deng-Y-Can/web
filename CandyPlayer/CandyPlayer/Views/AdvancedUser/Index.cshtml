@{
    ViewData["Title"] = "高级用户面板";
}

<div class="row mb-4">
    <div class="col">
        <h2 style="font-size:1.5rem;"><i class="fas fa-star"></i> 高级用户面板</h2>
        <p class="text-muted small">欢迎回来，高级用户！您拥有上传文件的权限。</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-6 col-md-3 mb-3">
        <div class="card stat-card h-100" style="background:linear-gradient(135deg,rgba(99,102,241,0.15),rgba(99,102,241,0.05))!important;border-color:rgba(99,102,241,0.2)!important;">
            <div class="card-body">
                <h5 class="small" style="text-transform:uppercase;letter-spacing:0.1em;opacity:0.8;">总文件数</h5>
                <h2 style="color:var(--primary-light);">@ViewBag.TotalFiles</h2>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3 mb-3">
        <div class="card stat-card h-100" style="background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(16,185,129,0.05))!important;border-color:rgba(16,185,129,0.2)!important;">
            <div class="card-body">
                <h5 class="small" style="text-transform:uppercase;letter-spacing:0.1em;opacity:0.8;">书籍</h5>
                <h2 style="color:var(--accent2);">@ViewBag.BookCount</h2>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3 mb-3">
        <div class="card stat-card h-100" style="background:linear-gradient(135deg,rgba(244,114,182,0.15),rgba(244,114,182,0.05))!important;border-color:rgba(244,114,182,0.2)!important;">
            <div class="card-body">
                <h5 class="small" style="text-transform:uppercase;letter-spacing:0.1em;opacity:0.8;">音乐</h5>
                <h2 style="color:var(--accent);">@ViewBag.MusicCount</h2>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3 mb-3">
        <div class="card stat-card h-100" style="background:linear-gradient(135deg,rgba(251,191,36,0.15),rgba(251,191,36,0.05))!important;border-color:rgba(251,191,36,0.2)!important;">
            <div class="card-body">
                <h5 class="small" style="text-transform:uppercase;letter-spacing:0.1em;opacity:0.8;">视频</h5>
                <h2 style="color:#fbbf24;">@ViewBag.VideoCount</h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-chart-line me-2" style="color:var(--primary-light);"></i>热门文件</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @if (ViewBag.TopFiles != null && ((List<CandyPlayer.Models.MediaFile>)ViewBag.TopFiles).Any())
                    {
                        foreach (var file in ViewBag.TopFiles as List<CandyPlayer.Models.MediaFile>)
                        {
                            <div class="col-6 col-md-3 mb-3">
                                <div class="card h-100">
                                    <div class="card-body text-center">
                                        @if (file.MediaType == CandyPlayer.Models.MediaType.Music)
                                        {
                                            <i class="fas fa-music text-primary fa-3x mb-2"></i>
                                        }
                                        else if (file.MediaType == CandyPlayer.Models.MediaType.Video)
                                        {
                                            <i class="fas fa-video text-danger fa-3x mb-2"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-book text-success fa-3x mb-2"></i>
                                        }
                                        <h6 class="card-title text-truncate small">@file.FileName</h6>
                                        <p class="card-text small text-muted">
                                            播放: @file.PlayCount 次
                                        </p>
                                        <a href="@Url.Action("Play", "Media", new { id = file.FileId })" class="btn btn-sm btn-primary">
                                            <i class="fas fa-play"></i> 播放
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">暂无数据</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
