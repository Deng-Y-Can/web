@{
    ViewData["Title"] = "高级用户面板";
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="fas fa-star"></i> 高级用户面板</h2>
        <p class="text-muted">欢迎回来，高级用户！您拥有上传文件的权限。</p>
    </div>
</div>

<div class="row">
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">总文件数</h5>
                <h2 class="mb-0">@ViewBag.TotalFiles</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">书籍</h5>
                <h2 class="mb-0">@ViewBag.BookCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title">音乐</h5>
                <h2 class="mb-0">@ViewBag.MusicCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">视频</h5>
                <h2 class="mb-0">@ViewBag.VideoCount</h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-chart-line"></i> 热门文件</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    @if (ViewBag.TopFiles != null && ((List<CandyPlayer.Models.MediaFile>)ViewBag.TopFiles).Any())
                    {
                        foreach (var file in ViewBag.TopFiles as List<CandyPlayer.Models.MediaFile>)
                        {
                            <div class="col-md-3 mb-3">
                                <div class="card h-100">
                                    <div class="card-body text-center">
                                        @if (file.MediaType == CandyPlayer.Models.MediaType.Music)
                                        {
                                            <i class="fas fa-music text-primary fa-3x mb-2"></i>
                                        }
                                        else if (file.MediaType == CandyPlayer.Models.MediaType.Video)
                                        {
                                            <i class="fas fa-video text-danger fa-3x mb-2"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-book text-success fa-3x mb-2"></i>
                                        }
                                        <h6 class="card-title text-truncate">@file.FileName</h6>
                                        <p class="card-text small text-muted">
                                            播放次数: @file.PlayCount<br />
                                            添加时间: @file.AddedTime.ToString("yyyy-MM-dd")
                                        </p>
                                        <a href="@Url.Action("Play", "Media", new { id = file.FileId })" class="btn btn-sm btn-primary">
                                            <i class="fas fa-play"></i> 播放
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">暂无数据</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>