@model List<CandyPlayer.Models.MediaFile>

@{
    ViewData["Title"] = "我的收藏";
    var selectedType = ViewBag.SelectedType as int?;
    var bookCount = ViewBag.BookCount as int? ?? 0;
    var musicCount = ViewBag.MusicCount as int? ?? 0;
    var videoCount = ViewBag.VideoCount as int? ?? 0;
    var totalCount = bookCount + musicCount + videoCount;
}

<style>
    .filter-tabs {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .filter-tab {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .filter-tab:hover {
        background: rgba(99,102,241,0.1);
        border-color: rgba(99,102,241,0.2);
        color: #fff;
    }

    .filter-tab.active {
        background: rgba(99,102,241,0.15);
        border-color: rgba(99,102,241,0.3);
        color: var(--primary-light);
        font-weight: 500;
    }

    .filter-tab .count {
        font-size: 0.7rem;
        padding: 2px 6px;
        border-radius: 10px;
        background: rgba(255,255,255,0.08);
    }

    .filter-tab.active .count {
        background: rgba(99,102,241,0.2);
    }

    .fav-card {
        position: relative;
        overflow: hidden;
        cursor: default;
    }

    .fav-card .fav-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        z-index: 2;
    }

    .fav-card .card-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
        font-size: 1.5rem;
        transition: transform 0.3s ease;
    }

    .fav-card:hover .card-icon {
        transform: scale(1.1);
    }

    .fav-card .card-actions {
        display: flex;
        gap: 6px;
        margin-top: 8px;
    }

    .fav-card .card-actions .btn {
        flex: 1;
        font-size: 0.8rem;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-state .empty-icon {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: rgba(244,114,182,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 2.5rem;
        animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
    }

    .empty-state h5 {
        color: var(--text-primary);
        font-weight: 600;
        margin-bottom: 8px;
    }

    .empty-state p {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 20px;
    }

    .quick-links {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .quick-link {
        padding: 10px 20px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        color: var(--text-secondary);
        text-decoration: none;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
    }

    .quick-link:hover {
        background: rgba(99,102,241,0.1);
        border-color: rgba(99,102,241,0.2);
        color: var(--primary-light);
        transform: translateY(-2px);
    }
</style>

<div class="fade-in-up">
    <div class="row mb-4">
        <div class="col">
            <h2 style="font-size:1.5rem;font-weight:700;">
                <i class="fas fa-heart me-2" style="color:var(--accent);"></i>我的收藏
            </h2>
            <p class="text-muted small">共收藏了 @totalCount 个媒体文件</p>
        </div>
    </div>

    <!-- 筛选标签 -->
    <div class="filter-tabs mb-4">
        <a href="@Url.Action("Index", new { mediaType = (int?)null })" class="filter-tab @(selectedType == null ? "active" : "")">
            <i class="fas fa-layer-group"></i> 全部
            <span class="count">@totalCount</span>
        </a>
        <a href="@Url.Action("Index", new { mediaType = 0 })" class="filter-tab @(selectedType == 0 ? "active" : "")">
            <i class="fas fa-book"></i> 书籍
            <span class="count">@bookCount</span>
        </a>
        <a href="@Url.Action("Index", new { mediaType = 1 })" class="filter-tab @(selectedType == 1 ? "active" : "")">
            <i class="fas fa-music"></i> 音乐
            <span class="count">@musicCount</span>
        </a>
        <a href="@Url.Action("Index", new { mediaType = 2 })" class="filter-tab @(selectedType == 2 ? "active" : "")">
            <i class="fas fa-video"></i> 视频
            <span class="count">@videoCount</span>
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="row g-3">
            @foreach (var file in Model)
            {
                <div class="col-6 col-md-4 col-lg-3 mb-3">
                    <div class="card fav-card h-100">
                        <div class="fav-badge" style="background:rgba(244,114,182,0.15);color:var(--accent);">
                            <i class="fas fa-heart"></i>
                        </div>
                        <div class="card-body text-center" style="padding-top:1.5rem;">
                            <div class="card-icon" style="background:@(file.MediaType == CandyPlayer.Models.MediaType.Music ? "rgba(99,102,241,0.1)" : file.MediaType == CandyPlayer.Models.MediaType.Video ? "rgba(248,113,113,0.1)" : "rgba(52,211,153,0.1)");color:@(file.MediaType == CandyPlayer.Models.MediaType.Music ? "var(--primary-light)" : file.MediaType == CandyPlayer.Models.MediaType.Video ? "#f87171" : "var(--accent2)");">
                                @if (file.MediaType == CandyPlayer.Models.MediaType.Music)
                                {
                                    <i class="fas fa-music"></i>
                                }
                                else if (file.MediaType == CandyPlayer.Models.MediaType.Video)
                                {
                                    <i class="fas fa-video"></i>
                                }
                                else
                                {
                                    <i class="fas fa-book"></i>
                                }
                            </div>
                            <h6 class="card-title text-truncate mb-1" title="@file.FileName" style="font-size:0.85rem;">@file.FileName</h6>
                            <p class="text-muted small mb-0" style="font-size:0.75rem;">
                                @file.FileExtension.ToUpper() · @(file.FileSize / 1024 / 1024) MB
                            </p>
                            <div class="card-actions">
                                <a href="@Url.Action("Play", "Media", new { id = file.FileId })" class="btn btn-sm btn-primary">
                                    @if (file.MediaType == CandyPlayer.Models.MediaType.Music)
                                    {
                                        <i class="fas fa-play me-1"></i>播放
                                    }
                                    else if (file.MediaType == CandyPlayer.Models.MediaType.Video)
                                    {
                                        <i class="fas fa-play me-1"></i>观看
                                    }
                                    else
                                    {
                                        <i class="fas fa-book-open me-1"></i>阅读
                                    }
                                </a>
                                <button class="btn btn-sm btn-outline-danger" onclick="removeFavorite(@file.FileId, this)" title="取消收藏">
                                    <i class="fas fa-heart-broken"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-heart" style="color:var(--accent);"></i>
            </div>
            <h5>暂无收藏</h5>
            <p>去发现您喜欢的媒体内容吧</p>
            <div class="quick-links">
                <a href="@Url.Action("Books", "Media")" class="quick-link">
                    <i class="fas fa-book" style="color:var(--accent2);"></i> 书籍
                </a>
                <a href="@Url.Action("Music", "Media")" class="quick-link">
                    <i class="fas fa-music" style="color:var(--primary-light);"></i> 音乐
                </a>
                <a href="@Url.Action("Videos", "Media")" class="quick-link">
                    <i class="fas fa-video" style="color:#f87171;"></i> 视频
                </a>
            </div>
        </div>
    }
</div>

<script>
    function removeFavorite(fileId, btn) {
        if (confirm('确定要取消收藏吗？')) {
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            var tokenValue = token ? token.value : '';

            fetch('/Favorite/Remove', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': tokenValue
                },
                body: 'fileId=' + fileId
            })
            .then(function(r) { return r.json(); })
            .then(function(result) {
                if (result.success) {
                    var card = btn.closest('.col-6, .col-md-4, .col-lg-3');
                    if (card) {
                        card.style.transition = 'all 0.4s ease';
                        card.style.opacity = '0';
                        card.style.transform = 'scale(0.8)';
                        setTimeout(function() { card.remove(); }, 400);
                    }
                    if (typeof showToast === 'function') showToast('已取消收藏', 'success');
                } else {
                    if (typeof showToast === 'function') showToast(result.message || '操作失败', 'error');
                    else alert(result.message || '操作失败');
                }
            })
            .catch(function() {
                if (typeof showToast === 'function') showToast('操作失败', 'error');
                else alert('操作失败');
            });
        }
    }
</script>
