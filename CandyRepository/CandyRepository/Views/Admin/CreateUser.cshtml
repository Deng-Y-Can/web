@{
    ViewData["Title"] = "添加用户";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2><i class="fas fa-user-plus"></i> 添加用户</h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-white">
                    <h5>用户信息</h5>
                </div>
                <div class="card-body">
                    <form id="createUserForm">
                        <div class="form-group">
                            <label>用户名</label>
                            <input type="text" id="username" class="form-control" required placeholder="请输入用户名">
                        </div>
                        <div class="form-group">
                            <label>密码</label>
                            <input type="password" id="password" class="form-control" required placeholder="请输入密码（至少6位）">
                        </div>
                        <div class="form-group">
                            <label>确认密码</label>
                            <input type="password" id="confirmPassword" class="form-control" required placeholder="请再次输入密码">
                        </div>
                        <div class="form-group">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" id="isAdmin" class="custom-control-input">
                                <label class="custom-control-label" for="isAdmin">设置为管理员</label>
                            </div>
                        </div>
                        <div class="form-group">
                            <button type="button" class="btn btn-primary" onclick="createUser()">
                                <i class="fas fa-save"></i> 添加用户
                            </button>
                            <a href="/Admin/Users" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> 返回
                            </a>
                        </div>
                        <div id="resultMessage" class="alert" style="display:none;"></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function createUser() {
            var username = $('#username').val().trim();
            var password = $('#password').val();
            var confirmPassword = $('#confirmPassword').val();
            var isAdmin = $('#isAdmin').is(':checked');

            if (!username) {
                showMessage('请输入用户名', 'danger');
                return;
            }

            if (!password) {
                showMessage('请输入密码', 'danger');
                return;
            }

            if (password.length < 6) {
                showMessage('密码长度至少为6位', 'danger');
                return;
            }

            if (password !== confirmPassword) {
                showMessage('两次输入的密码不一致', 'danger');
                return;
            }

            $.ajax({
                url: '/Admin/CreateUser',
                type: 'POST',
                data: {
                    username: username,
                    password: password,
                    isAdmin: isAdmin
                },
                success: function(result) {
                    if (result.success) {
                        showMessage(result.message, 'success');
                        setTimeout(function() {
                            window.location.href = '/Admin/Users';
                        }, 1500);
                    } else {
                        showMessage(result.message, 'danger');
                    }
                },
                error: function() {
                    showMessage('添加失败，请重试', 'danger');
                }
            });
        }

        function showMessage(message, type) {
            $('#resultMessage').removeClass('alert-success alert-danger').addClass('alert-' + type);
            $('#resultMessage').html('<i class="fas fa-' + (type === 'success' ? 'check-circle' : 'exclamation-circle') + '"></i> ' + message);
            $('#resultMessage').show();
            setTimeout(function() {
                $('#resultMessage').fadeOut();
            }, 3000);
        }
    </script>
}