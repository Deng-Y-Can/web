@using CandyRepository.Models
@{
    ViewData["Title"] = "用户管理";
    var users = ViewBag.Users as List<User> ?? new List<User>();
    var currentPage = ViewBag.CurrentPage;
    var totalPages = ViewBag.TotalPages;
    var search = ViewBag.Search;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2><i class="fas fa-users"></i> 用户管理</h2>
            <hr />
        </div>
    </div>

    <!-- 搜索栏 -->
    <div class="row mb-3">
        <div class="col-md-6">
            <form method="get" class="form-inline">
                <div class="input-group">
                    <input type="text" name="search" class="form-control" placeholder="搜索用户名..." value="@search">
                    <div class="input-group-append">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-search"></i> 搜索
                        </button>
                    </div>
                </div>
            </form>
        </div>
        <div class="col-md-6 text-right">
            <a href="/Admin/CreateUser" class="btn btn-success">
                <i class="fas fa-user-plus"></i> 添加用户
            </a>
            <a href="/Admin/Users" class="btn btn-secondary ml-2">
                <i class="fas fa-refresh"></i> 刷新
            </a>
        </div>
    </div>

    <!-- 用户列表 -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-white">
                    <h5><i class="fas fa-list"></i> 用户列表</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>用户名</th>
                                    <th>角色</th>
                                    <th>状态</th>
                                    <th>创建时间</th>
                                    <th>最后登录</th>
                                    <th>操作</th>
                            </thead>
                            <tbody>
                                @if (users.Any())
                                {
                                    @foreach (var user in users)
                                    {
                                        <tr>
                                            <td>@user.Id</td>
                                            <td>@user.Username</td>
                                            <td>
                                                @if (user.IsAdmin)
                                                {
                                                    <span class="badge badge-danger">管理员</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-info">普通用户</span>
                                                }
                                            </td>
                                            <td>
                                                @if (user.IsActive)
                                                {
                                                    <span class="badge badge-success">启用</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary">禁用</span>
                                                }
                                            </td>
                                            <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                                            <td>@(user.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "从未登录")</td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-warning" onclick="resetPassword(@user.Id)" title="重置密码">
                                                        <i class="fas fa-key"></i>
                                                    </button>
                                                    @if (!user.IsAdmin)
                                                    {
                                                        <button class="btn @(user.IsActive ? "btn-danger" : "btn-success")" onclick="toggleUserStatus(@user.Id)" title="@(user.IsActive ? "禁用" : "启用")">
                                                            <i class="fas @(user.IsActive ? "fa-ban" : "fa-check")"></i>
                                                        </button>
                                                        <button class="btn btn-danger" onclick="deleteUser(@user.Id)" title="删除用户">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted">暂无用户</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- 分页 -->
                    @if (totalPages > 1)
                    {
                        <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-center">
                                @if (currentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="?page=@(currentPage-1)&search=@search">上一页</a>
                                    </li>
                                }
                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    if (i == currentPage)
                                    {
                                        <li class="page-item active">
                                            <span class="page-link">@i</span>
                                        </li>
                                    }
                                    else
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="?page=@i&search=@search">@i</a>
                                        </li>
                                    }
                                }
                                @if (currentPage < totalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="?page=@(currentPage+1)&search=@search">下一页</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function resetPassword(userId) {
            if (confirm("确定要重置此用户的密码吗？新密码将设置为 123456")) {
                $.post('/Admin/ResetPassword', { userId: userId }, function(result) {
                    if (result.success) {
                        alert(result.message);
                    } else {
                        alert(result.message);
                    }
                });
            }
        }

        function toggleUserStatus(userId) {
            if (confirm("确定要更改此用户的状态吗？")) {
                $.post('/Admin/ToggleUserStatus', { userId: userId }, function(result) {
                    if (result.success) {
                        location.reload();
                    } else {
                        alert(result.message);
                    }
                });
            }
        }

        function deleteUser(userId) {
            if (confirm("确定要删除此用户吗？此操作不可恢复！\n\n注意：用户如果有文件或文件夹将无法删除，请先删除或转移其文件。")) {
                $.post('/Admin/DeleteUser', { userId: userId }, function(result) {
                    if (result.success) {
                        alert(result.message);
                        location.reload();
                    } else {
                        alert(result.message);
                    }
                });
            }
        }
    </script>
}