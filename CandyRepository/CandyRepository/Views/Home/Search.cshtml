@{
    ViewData["Title"] = "搜索文件";
    var results = ViewBag.Results as List<CandyRepository.Models.File> ?? new List<CandyRepository.Models.File>();
    var keyword = ViewBag.Keyword as string;
    var fileType = ViewBag.FileType as string;
    var startDate = ViewBag.StartDate as DateTime?;
    var endDate = ViewBag.EndDate as DateTime?;
    var minSize = ViewBag.MinSize as long?;
    var maxSize = ViewBag.MaxSize as long?;
    var userId = Context.Session.GetInt32("UserId");
    var isAdmin = Context.Session.GetString("IsAdmin") == "True";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-white">
                    <h5><i class="fas fa-search"></i> 文件搜索</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Search" method="get">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>关键词</label>
                                    <input type="text" name="keyword" class="form-control" value="@keyword" placeholder="文件名关键字...">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>文件类型</label>
                                    <select name="fileType" class="form-control">
                                        <option value="">全部</option>
                                        @{
                                            var isImage = fileType == "image";
                                            var isText = fileType == "text";
                                            var isPdf = fileType == "application/pdf";
                                            var isWord = fileType == "application/msword";
                                            var isExcel = fileType == "application/vnd.ms-excel";
                                            var isZip = fileType == "application/zip";
                                        }
                                        @if (isImage)
                                        {
                                            <option value="image" selected="selected">图片</option>
                                        }
                                        else
                                        {
                                            <option value="image">图片</option>
                                        }

                                        @if (isText)
                                        {
                                            <option value="text" selected="selected">文本</option>
                                        }
                                        else
                                        {
                                            <option value="text">文本</option>
                                        }

                                        @if (isPdf)
                                        {
                                            <option value="application/pdf" selected="selected">PDF</option>
                                        }
                                        else
                                        {
                                            <option value="application/pdf">PDF</option>
                                        }

                                        @if (isWord)
                                        {
                                            <option value="application/msword" selected="selected">Word</option>
                                        }
                                        else
                                        {
                                            <option value="application/msword">Word</option>
                                        }

                                        @if (isExcel)
                                        {
                                            <option value="application/vnd.ms-excel" selected="selected">Excel</option>
                                        }
                                        else
                                        {
                                            <option value="application/vnd.ms-excel">Excel</option>
                                        }

                                        @if (isZip)
                                        {
                                            <option value="application/zip" selected="selected">压缩包</option>
                                        }
                                        else
                                        {
                                            <option value="application/zip">压缩包</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>开始日期</label>
                                    <input type="date" name="startDate" class="form-control" value="@(startDate?.ToString("yyyy-MM-dd"))">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>结束日期</label>
                                    <input type="date" name="endDate" class="form-control" value="@(endDate?.ToString("yyyy-MM-dd"))">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>&nbsp;</label>
                                    <button type="submit" class="btn btn-primary btn-block">
                                        <i class="fas fa-search"></i> 搜索
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>最小文件大小(KB)</label>
                                    <input type="number" name="minSize" class="form-control" value="@(minSize.HasValue ? minSize.Value / 1024 : (object)string.Empty)" placeholder="最小大小(KB)">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>最大文件大小(KB)</label>
                                    <input type="number" name="maxSize" class="form-control" value="@(maxSize.HasValue ? maxSize.Value / 1024 : (object)string.Empty)" placeholder="最大大小(KB)">
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(keyword) || !string.IsNullOrEmpty(fileType) || startDate.HasValue || endDate.HasValue || minSize.HasValue || maxSize.HasValue)
    {
        <div class="row mt-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-white">
                        <h5><i class="fas fa-file"></i> 搜索结果 (@results.Count 个文件)</h5>
                    </div>
                    <div class="card-body">
                        @if (results.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>文件名</th>
                                            <th>大小</th>
                                            <th>类型</th>
                                            <th>位置</th>
                                            <th>上传时间</th>
                                            <th>上传者</th>
                                            <th>操作</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var file in results)
                                        {
                                            var canEdit = file.UploadedById == userId || isAdmin;
                                            <tr>
                                                <td>
                                                    <i class="fas fa-file"></i>
                                                    @file.Name
                                                </td>
                                                <td>@FormatFileSize(file.Size)</td>
                                                <td>@(file.ContentType?.Split('/').LastOrDefault() ?? "未知")</td>
                                                <td>
                                                    <a href="/Folder/Index?folderId=@file.FolderId" class="text-primary">
                                                        <i class="fas fa-folder"></i> @(file.Folder?.Name ?? "根目录")
                                                    </a>
                                                </td>
                                                <td>@file.UploadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                                <td>@(file.UploadedBy?.Username ?? "未知")</td>
                                                <td>
                                                    <div class="btn-group btn-group-sm">
                                                        <a href="#" onclick="downloadFile(@file.Id)" class="btn btn-info">
                                                            <i class="fas fa-download"></i>
                                                        </a>
                                                        @if (canEdit)
                                                        {
                                                            <button onclick="deleteFile(@file.Id)" class="btn btn-danger">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info text-center">
                                <i class="fas fa-info-circle"></i> 没有找到匹配的文件
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@functions {
    public string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

@section Scripts {
    <script>
        function downloadFile(fileId) {
            window.location.href = `/File/Download/${fileId}`;
        }

        function deleteFile(fileId) {
            if (confirm("确定要删除此文件吗？")) {
                $.post('/File/Delete', { id: fileId }, function(result) {
                    if (result.success) {
                        location.reload();
                    } else {
                        alert(result.message);
                    }
                });
            }
        }
    </script>
}