{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=E:\\CandyRepository\\candyrepository.db"
  },
  "Storage": {
    "RootPath": "E:\\CandyRepository\\",
    "MaxFileSize": 104857600,
    "LogRetentionDays": 90,
    "RecycleBinRetentionDays": 30,
    "MaxFolderDepth": 10,
    "MaxFilesPerFolder": 5000
  },
  "FilePreview": {
    "ImageTypes": "image/jpeg,image/png,image/gif,image/webp",
    "TextTypes": "text/plain,text/html,text/css,text/javascript,application/json",
    "PdfTypes": "application/pdf"
  }
}