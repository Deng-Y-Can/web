<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CandyNote - 个人笔记系统</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f5f7fa;
            height: 100vh;
            overflow: hidden;
        }

        .app {
            display: flex;
            height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: white;
            border-right: 1px solid #e1e5e9;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .sidebar-header {
            padding: 20px;
            border-bottom: 1px solid #e1e5e9;
        }

            .sidebar-header h2 {
                font-size: 20px;
                color: #667eea;
                margin-bottom: 5px;
            }

        .user-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 10px;
            font-size: 14px;
            color: #666;
        }

        .logout-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: #999;
            font-size: 14px;
        }

            .logout-btn:hover {
                color: #c33;
            }

        .collections-nav {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
        }

            .collections-nav ul {
                list-style: none;
            }

        .collection-item {
            margin: 5px 0;
        }

        .collection-header {
            display: flex;
            align-items: center;
            padding: 8px 10px;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s;
        }

            .collection-header:hover {
                background: #f5f7fa;
            }

            .collection-header .toggle-icon {
                width: 20px;
                font-size: 12px;
                color: #999;
            }

            .collection-header .folder-icon {
                width: 20px;
                color: #ffc107;
                margin-right: 8px;
            }

            .collection-header .name {
                flex: 1;
                font-size: 14px;
                cursor: pointer;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

                .collection-header .name:hover {
                    color: #667eea;
                }

            .collection-header .permission-icon {
                margin-left: 8px;
                font-size: 11px;
            }

            .collection-header .actions {
                display: none;
            }

            .collection-header:hover .actions {
                display: flex;
                gap: 8px;
            }

        .actions button {
            background: none;
            border: none;
            cursor: pointer;
            color: #999;
            font-size: 12px;
            padding: 2px 5px;
        }

            .actions button:hover {
                color: #667eea;
            }

        .collection-children {
            margin-left: 20px;
            display: none;
        }

            .collection-children.open {
                display: block;
            }

        .note-item {
            padding: 8px 10px 8px 35px;
            font-size: 13px;
            cursor: pointer;
            border-radius: 8px;
            transition: background 0.2s;
            color: #666;
        }

            .note-item:hover {
                background: #f5f7fa;
                color: #667eea;
            }

        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .main-header {
            background: white;
            padding: 15px 30px;
            border-bottom: 1px solid #e1e5e9;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .search-box {
            display: flex;
            gap: 10px;
        }

            .search-box input {
                padding: 8px 15px;
                border: 1px solid #e1e5e9;
                border-radius: 20px;
                width: 250px;
                outline: none;
            }

                .search-box input:focus {
                    border-color: #667eea;
                }

        .btn-primary {
            background: #667eea;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 14px;
        }

            .btn-primary:hover {
                background: #5a67d8;
            }

        .content {
            flex: 1;
            overflow-y: auto;
            padding: 30px;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-left: 4px solid #28a745;
            animation: slideDown 0.3s ease-out;
        }

        .alert-error {
            background: #f8d7da;
            color: #721c24;
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-left: 4px solid #dc3545;
            animation: slideDown 0.3s ease-out;
        }

        /* 模态框样式 */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10000;
        }

        .modal-content {
            background: white;
            border-radius: 12px;
            padding: 25px;
            width: 450px;
            max-width: 90%;
            animation: slideIn 0.3s ease-out;
        }

            .modal-content h3 {
                margin-bottom: 20px;
                color: #333;
            }

            .modal-content .form-group {
                margin-bottom: 15px;
            }

            .modal-content label {
                display: block;
                margin-bottom: 5px;
                font-weight: 500;
                color: #555;
            }

            .modal-content input,
            .modal-content textarea,
            .modal-content select {
                width: 100%;
                padding: 8px 12px;
                border: 1px solid #ddd;
                border-radius: 6px;
                font-size: 14px;
                font-family: inherit;
            }

            .modal-content textarea {
                resize: vertical;
            }

                .modal-content input:focus,
                .modal-content textarea:focus,
                .modal-content select:focus {
                    outline: none;
                    border-color: #667eea;
                }

        .modal-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 20px;
        }

            .modal-actions button {
                padding: 8px 20px;
                border-radius: 6px;
                cursor: pointer;
                font-size: 14px;
                transition: all 0.2s;
            }

            .modal-actions .btn-confirm {
                background: #667eea;
                color: white;
                border: none;
            }

                .modal-actions .btn-confirm:hover {
                    background: #5a67d8;
                }

            .modal-actions .btn-cancel {
                background: #f5f7fa;
                border: 1px solid #ddd;
            }

                .modal-actions .btn-cancel:hover {
                    background: #e5e9f0;
                }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="app">
        <div class="sidebar">
            <div class="sidebar-header">
                <h2>📝 CandyNote</h2>
                <div class="user-info">
                    <span><i class="fas fa-user"></i> @User.Identity?.Name</span>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Users" style="color: #667eea; margin-left: 10px;">
                            <i class="fas fa-cog"></i> 管理
                        </a>
                    }
                    <form asp-action="Logout" asp-controller="Account" method="post" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="logout-btn">
                            <i class="fas fa-sign-out-alt"></i> 退出
                        </button>
                    </form>
                </div>
            </div>
            <div class="collections-nav" id="collectionsNav">
                <div id="collectionTree">
                    <div style="text-align: center; padding: 20px; color: #999;">
                        <i class="fas fa-spinner fa-spin"></i> 加载中...
                    </div>
                </div>
                <button class="btn-primary" style="width: 100%; margin-top: 15px;" onclick="showCreateCollectionDialog()">
                    <i class="fas fa-plus"></i> 新建合集
                </button>
            </div>
        </div>
        <div class="main">
            <div class="main-header">
                <h3 id="currentCollectionTitle">所有笔记</h3>
                <div class="search-box">
                    <input type="text" id="searchInput" placeholder="搜索笔记..." onkeypress="if(event.keyCode==13) searchNotes()" />
                    <button class="btn-primary" onclick="searchNotes()">搜索</button>
                </div>
            </div>
            <div class="content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script>
        // 全局变量
        let editingCollectionId = null;

        async function loadCollections() {
            try {
                const response = await fetch('/api/collections');
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }
                const data = await response.json();
                renderCollectionTree(data);
            } catch (error) {
                console.error('加载合集失败:', error);
                document.getElementById('collectionTree').innerHTML =
                    '<div style="color: #c33; text-align: center; padding: 20px;">加载失败，请刷新页面重试</div>';
            }
        }

        function renderCollectionTree(collections) {
            const container = document.getElementById('collectionTree');
            if (!collections || collections.length === 0) {
                container.innerHTML = '<div style="color: #999; text-align: center; padding: 20px;">📁 暂无合集和笔记<br/>点击下方按钮创建第一个合集</div>';
                return;
            }

            const ul = document.createElement('ul');
            ul.style.listStyle = 'none';

            for (const item of collections) {
                if (item.type === 'collection') {
                    const li = document.createElement('li');
                    li.className = 'collection-item';

                    const header = document.createElement('div');
                    header.className = 'collection-header';

                    const toggleIcon = document.createElement('span');
                    toggleIcon.className = 'toggle-icon';
                    toggleIcon.innerHTML = '<i class="fas fa-chevron-right"></i>';

                    const folderIcon = document.createElement('span');
                    folderIcon.className = 'folder-icon';
                    folderIcon.innerHTML = '<i class="fas fa-folder"></i>';

                    const nameSpan = document.createElement('span');
                    nameSpan.className = 'name';
                    nameSpan.textContent = item.name;
                    nameSpan.title = item.description || '';
                    nameSpan.onclick = (e) => {
                        e.stopPropagation();
                        loadNotesByCollection(item.id);
                    };

                    const permissionIcon = document.createElement('span');
                    permissionIcon.className = 'permission-icon';
                    if (item.permission === 'Public') {
                        permissionIcon.innerHTML = '<i class="fas fa-globe" style="color: #28a745;"></i>';
                        permissionIcon.title = '公开合集';
                    } else {
                        permissionIcon.innerHTML = '<i class="fas fa-lock" style="color: #dc3545;"></i>';
                        permissionIcon.title = '私有合集';
                    }

                    const actions = document.createElement('div');
                    actions.className = 'actions';
                    actions.innerHTML = `
                        <button onclick="event.stopPropagation(); viewCollectionDetail(${item.id})" title="详情"><i class="fas fa-info-circle"></i></button>
                        <button onclick="event.stopPropagation(); showEditCollectionDialog(${item.id}, '${escapeHtml(item.name)}', '${escapeHtml(item.description || '')}', '${item.permission}')" title="编辑"><i class="fas fa-edit"></i></button>
                        <button onclick="event.stopPropagation(); deleteCollection(${item.id})" title="删除"><i class="fas fa-trash"></i></button>
                        <button onclick="event.stopPropagation(); showCreateSubCollectionDialog(${item.id})" title="新建子合集"><i class="fas fa-plus"></i></button>
                    `;

                    header.appendChild(toggleIcon);
                    header.appendChild(folderIcon);
                    header.appendChild(nameSpan);
                    header.appendChild(permissionIcon);
                    header.appendChild(actions);

                    const childrenDiv = document.createElement('div');
                    childrenDiv.className = 'collection-children';

                    if (item.notes && item.notes.length > 0) {
                        for (const note of item.notes) {
                            const noteDiv = document.createElement('div');
                            noteDiv.className = 'note-item';
                            noteDiv.innerHTML = `<i class="fas fa-file-alt" style="margin-right: 8px; color: #999;"></i>${escapeHtml(note.title)}`;
                            noteDiv.onclick = () => viewNote(note.id);
                            childrenDiv.appendChild(noteDiv);
                        }
                    }

                    if (item.children && item.children.length > 0) {
                        renderChildren(item.children, childrenDiv);
                    }

                    li.appendChild(header);
                    li.appendChild(childrenDiv);
                    ul.appendChild(li);

                    header.onclick = (e) => {
                        if (e.target !== header && !actions.contains(e.target)) return;
                        const isOpen = childrenDiv.classList.contains('open');
                        if (isOpen) {
                            childrenDiv.classList.remove('open');
                            toggleIcon.innerHTML = '<i class="fas fa-chevron-right"></i>';
                        } else {
                            childrenDiv.classList.add('open');
                            toggleIcon.innerHTML = '<i class="fas fa-chevron-down"></i>';
                        }
                    };
                } else if (item.type === 'note') {
                    const noteDiv = document.createElement('div');
                    noteDiv.className = 'note-item';
                    noteDiv.style.marginLeft = '0px';
                    noteDiv.innerHTML = `<i class="fas fa-file-alt" style="margin-right: 8px; color: #999;"></i>${escapeHtml(item.title)}`;
                    noteDiv.onclick = () => viewNote(item.id);
                    ul.appendChild(noteDiv);
                }
            }

            container.innerHTML = '';
            container.appendChild(ul);
        }

        function renderChildren(children, parentElement) {
            for (const child of children) {
                if (child.type === 'collection') {
                    const childDiv = document.createElement('div');
                    childDiv.style.marginLeft = '20px';
                    childDiv.style.marginTop = '5px';

                    const header = document.createElement('div');
                    header.className = 'collection-header';
                    header.style.paddingLeft = '20px';

                    const toggleIcon = document.createElement('span');
                    toggleIcon.className = 'toggle-icon';
                    toggleIcon.innerHTML = '<i class="fas fa-chevron-right"></i>';

                    const folderIcon = document.createElement('span');
                    folderIcon.className = 'folder-icon';
                    folderIcon.innerHTML = '<i class="fas fa-folder"></i>';

                    const nameSpan = document.createElement('span');
                    nameSpan.className = 'name';
                    nameSpan.textContent = child.name;
                    nameSpan.title = child.description || '';
                    nameSpan.onclick = (e) => {
                        e.stopPropagation();
                        loadNotesByCollection(child.id);
                    };

                    const permissionIcon = document.createElement('span');
                    permissionIcon.className = 'permission-icon';
                    if (child.permission === 'Public') {
                        permissionIcon.innerHTML = '<i class="fas fa-globe" style="color: #28a745;"></i>';
                        permissionIcon.title = '公开合集';
                    } else {
                        permissionIcon.innerHTML = '<i class="fas fa-lock" style="color: #dc3545;"></i>';
                        permissionIcon.title = '私有合集';
                    }

                    const actions = document.createElement('div');
                    actions.className = 'actions';
                    actions.innerHTML = `
                        <button onclick="event.stopPropagation(); viewCollectionDetail(${child.id})" title="详情"><i class="fas fa-info-circle"></i></button>
                        <button onclick="event.stopPropagation(); showEditCollectionDialog(${child.id}, '${escapeHtml(child.name)}', '${escapeHtml(child.description || '')}', '${child.permission}')" title="编辑"><i class="fas fa-edit"></i></button>
                        <button onclick="event.stopPropagation(); deleteCollection(${child.id})" title="删除"><i class="fas fa-trash"></i></button>
                        <button onclick="event.stopPropagation(); showCreateSubCollectionDialog(${child.id})" title="新建子合集"><i class="fas fa-plus"></i></button>
                    `;

                    header.appendChild(toggleIcon);
                    header.appendChild(folderIcon);
                    header.appendChild(nameSpan);
                    header.appendChild(permissionIcon);
                    header.appendChild(actions);

                    const childrenDiv = document.createElement('div');
                    childrenDiv.className = 'collection-children';

                    if (child.notes && child.notes.length > 0) {
                        for (const note of child.notes) {
                            const noteDiv = document.createElement('div');
                            noteDiv.className = 'note-item';
                            noteDiv.innerHTML = `<i class="fas fa-file-alt" style="margin-right: 8px; color: #999;"></i>${escapeHtml(note.title)}`;
                            noteDiv.onclick = () => viewNote(note.id);
                            childrenDiv.appendChild(noteDiv);
                        }
                    }

                    if (child.children && child.children.length > 0) {
                        renderChildren(child.children, childrenDiv);
                    }

                    childDiv.appendChild(header);
                    childDiv.appendChild(childrenDiv);
                    parentElement.appendChild(childDiv);

                    header.onclick = (e) => {
                        e.stopPropagation();
                        const isOpen = childrenDiv.classList.contains('open');
                        if (isOpen) {
                            childrenDiv.classList.remove('open');
                            toggleIcon.innerHTML = '<i class="fas fa-chevron-right"></i>';
                        } else {
                            childrenDiv.classList.add('open');
                            toggleIcon.innerHTML = '<i class="fas fa-chevron-down"></i>';
                        }
                    };
                }
            }
        }

        function viewCollectionDetail(id) {
            window.location.href = `/Collection/Detail/${id}`;
        }

        function loadNotesByCollection(collectionId) {
            window.location.href = `/Home/Index?collectionId=${collectionId}`;
        }

        function viewNote(noteId) {
            window.location.href = `/Note/View/${noteId}`;
        }

        function showCreateCollectionDialog() {
            showCollectionDialog(null, null, null, null, false);
        }

        function showCreateSubCollectionDialog(parentId) {
            showCollectionDialog(parentId, null, null, null, false);
        }

        function showEditCollectionDialog(id, name, description, permission) {
            showCollectionDialog(null, id, name, description, true, permission);
        }

        function showCollectionDialog(parentId, editId, editName, editDescription, isEdit, editPermission) {
            const title = isEdit ? '编辑合集' : (parentId ? '新建子合集' : '新建合集');
            const name = isEdit ? editName : '';
            const description = isEdit ? editDescription : '';
            const permission = isEdit ? editPermission : 'Private';

            const modalHtml = `
                <div id="collectionModal" class="modal-overlay">
                    <div class="modal-content">
                        <h3>${title}</h3>
                        <div class="form-group">
                            <label>合集名称 *</label>
                            <input type="text" id="collectionName" value="${escapeHtml(name)}" placeholder="请输入合集名称" />
                        </div>
                        <div class="form-group">
                            <label>合集简介</label>
                            <textarea id="collectionDescription" rows="3" placeholder="请输入合集简介（可选）">${escapeHtml(description)}</textarea>
                        </div>
                        <div class="form-group">
                            <label>权限</label>
                            <select id="collectionPermission">
                                <option value="0" ${permission === 'Private' ? 'selected' : ''}>🔒 私有 - 仅自己可见</option>
                                <option value="1" ${permission === 'Public' ? 'selected' : ''}>🌍 公开 - 所有人可见</option>
                            </select>
                        </div>
                        <div class="modal-actions">
                            <button class="btn-cancel" onclick="closeCollectionModal()">取消</button>
                            <button class="btn-confirm" onclick="submitCollection(${parentId !== null ? parentId : 'null'}, ${editId !== null ? editId : 'null'})">${isEdit ? '保存修改' : '创建'}</button>
                        </div>
                    </div>
                </div>
            `;

            document.body.insertAdjacentHTML('beforeend', modalHtml);

            // 按回车提交
            document.getElementById('collectionName').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    submitCollection(parentId, editId);
                }
            });
        }

        function closeCollectionModal() {
            const modal = document.getElementById('collectionModal');
            if (modal) modal.remove();
        }

        async function submitCollection(parentId, editId) {
            const name = document.getElementById('collectionName').value.trim();
            const description = document.getElementById('collectionDescription').value.trim();
            const permission = parseInt(document.getElementById('collectionPermission').value);

            if (!name) {
                alert('请输入合集名称');
                return;
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            let url, body;

            if (editId) {
                url = `/Collection/Edit/${editId}`;
                body = `name=${encodeURIComponent(name)}&description=${encodeURIComponent(description)}&permission=${permission}`;
            } else {
                url = '/Collection/Create';
                body = `name=${encodeURIComponent(name)}&description=${encodeURIComponent(description)}&parentId=${parentId}&permission=${permission}`;
            }

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: body
                });

                if (response.redirected) {
                    window.location.href = response.url;
                } else {
                    const result = await response.json();
                    if (result.success) {
                        location.reload();
                    } else {
                        alert('操作失败：' + result.message);
                    }
                }
            } catch (error) {
                alert('操作失败：' + error);
            }

            closeCollectionModal();
        }

        async function deleteCollection(id) {
            if (confirm('确定要删除这个合集吗？合集内的笔记和子合集将变为未分类状态。')) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch(`/Collection/Delete/${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });
                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('删除失败：' + result.message);
                }
            }
        }

        function searchNotes() {
            const keyword = document.getElementById('searchInput').value.trim();
            if (keyword) {
                window.location.href = `/Home/Search?keyword=${encodeURIComponent(keyword)}`;
            }
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        document.addEventListener('DOMContentLoaded', function() {
            loadCollections();
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>